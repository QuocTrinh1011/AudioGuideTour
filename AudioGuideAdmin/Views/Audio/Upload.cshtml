@model IEnumerable<AudioController.AudioFileItem>

<h2 class="mb-3">Thư viện audio</h2>
<p class="text-muted">Upload file audio du phong roi copy URL gan vao POI hoac Translation de dung khi TTS gap loi.</p>

<form method="post" enctype="multipart/form-data" class="card p-3 mb-3">
    @Html.AntiForgeryToken()
    <div class="row g-2">
        <div class="col-md-9">
            <input type="file" name="file" class="form-control" />
        </div>
        <div class="col-md-3">
            <button class="btn btn-primary w-100">Upload audio</button>
        </div>
    </div>
</form>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead><tr><th>File</th><th>Preview</th><th>URL</th><th></th></tr></thead>
            <tbody>
            @foreach (var file in Model)
            {
                <tr>
                    <td>@file.FileName</td>
                    <td><audio controls src="@file.Url" style="height: 32px;"></audio></td>
                    <td><input value="@file.Url" class="form-control" readonly /></td>
                    <td class="text-end">
                        <form method="post" action="/Audio/Delete" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="fileName" value="@file.FileName" />
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa file audio này?')">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
