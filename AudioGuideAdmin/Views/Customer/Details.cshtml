@model AudioGuideAdmin.ViewModels.CustomerDetailViewModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Chi tiết khách hàng</h2>
        <p class="text-muted mb-0">Theo dõi trạng thái tài khoản app sau khi khách thanh toán.</p>
    </div>
    <a class="btn btn-outline-secondary" href="/Customer">Quay lại</a>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card p-4 h-100">
            <h5 class="mb-3">Tài khoản app</h5>
            <dl class="row mb-0">
                <dt class="col-sm-4">Họ tên</dt>
                <dd class="col-sm-8">@Model.Account.FullName</dd>

                <dt class="col-sm-4">Số điện thoại</dt>
                <dd class="col-sm-8">@Model.Account.Phone</dd>

                <dt class="col-sm-4">Email</dt>
                <dd class="col-sm-8">@Model.Account.Email</dd>

                <dt class="col-sm-4">Ngôn ngữ</dt>
                <dd class="col-sm-8">@Model.Account.PreferredLanguage</dd>

                <dt class="col-sm-4">Trạng thái</dt>
                <dd class="col-sm-8">
                    <span class="badge @(Model.Account.IsActive ? "bg-success" : "bg-secondary")">
                        @(Model.Account.IsActive ? "Đang hoạt động" : Model.Account.Status)
                    </span>
                </dd>

                <dt class="col-sm-4">Thanh toán</dt>
                <dd class="col-sm-8">
                    <span class="badge @(Model.Account.IsPaid ? "bg-primary" : "bg-warning text-dark")">
                        @(Model.Account.IsPaid ? "Đã thanh toán" : "Chưa thanh toán")
                    </span>
                </dd>

                <dt class="col-sm-4">Kích hoạt lúc</dt>
                <dd class="col-sm-8">@(Model.Account.PaidAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

                <dt class="col-sm-4">Đăng nhập gần nhất</dt>
                <dd class="col-sm-8">@(Model.Account.LastLoginAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>
            </dl>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card p-4">
            <h5 class="mb-3">Hồ sơ đăng ký</h5>
            @if (Model.Registration == null)
            {
                <div class="text-muted">Không tìm thấy hồ sơ đăng ký liên kết.</div>
            }
            else
            {
                <dl class="row mb-0">
                    <dt class="col-sm-4">Mã hồ sơ</dt>
                    <dd class="col-sm-8">@Model.Registration.Id</dd>

                    <dt class="col-sm-4">Gói</dt>
                    <dd class="col-sm-8">@Model.PlanName</dd>

                    <dt class="col-sm-4">Visitor</dt>
                    <dd class="col-sm-8">@Model.Registration.VisitorId</dd>

                    <dt class="col-sm-4">Thiết bị</dt>
                    <dd class="col-sm-8">@Model.Registration.DeviceId</dd>

                    <dt class="col-sm-4">Payment status</dt>
                    <dd class="col-sm-8">@Model.Registration.PaymentStatus</dd>

                    <dt class="col-sm-4">Order code</dt>
                    <dd class="col-sm-8">@(Model.Registration.OrderCode?.ToString() ?? "-")</dd>

                    <dt class="col-sm-4">Checkout</dt>
                    <dd class="col-sm-8 text-break">@Model.Registration.CheckoutUrl</dd>

                    <dt class="col-sm-4">Thanh toán lúc</dt>
                    <dd class="col-sm-8">@(Model.Registration.PaidAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>
                </dl>
            }
        </div>
    </div>
</div>
