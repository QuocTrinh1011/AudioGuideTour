@model AudioGuideAdmin.ViewModels.CustomerIndexViewModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Khách hàng đã đăng ký</h2>
        <p class="text-muted mb-0">Danh sách tài khoản khách dùng app sau khi hoàn tất thanh toán.</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card p-3">
            <div class="text-muted small">Tổng tài khoản</div>
            <div class="fs-3 fw-bold">@Model.TotalCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3">
            <div class="text-muted small">Đang hoạt động</div>
            <div class="fs-3 fw-bold text-success">@Model.ActiveCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3">
            <div class="text-muted small">Đã thanh toán</div>
            <div class="fs-3 fw-bold text-primary">@Model.PaidCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3">
            <div class="text-muted small">Chờ kích hoạt</div>
            <div class="fs-3 fw-bold text-warning">@Model.PendingCount</div>
        </div>
    </div>
</div>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Khách hàng</th>
                    <th>Liên hệ</th>
                    <th>Gói</th>
                    <th>Trạng thái</th>
                    <th>Thanh toán</th>
                    <th class="text-end">Xem</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Chưa có tài khoản khách hàng nào.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@item.Account.FullName</div>
                                <div class="small text-muted">@item.Account.PreferredLanguage</div>
                            </td>
                            <td>
                                <div>@item.Account.Phone</div>
                                <div class="small text-muted">@item.Account.Email</div>
                            </td>
                            <td>@item.PlanName</td>
                            <td>
                                <span class="badge @(item.Account.IsActive ? "bg-success" : "bg-secondary")">
                                    @(item.Account.IsActive ? "Đang hoạt động" : item.RegistrationStatus)
                                </span>
                            </td>
                            <td>
                                <span class="badge @(item.Account.IsPaid ? "bg-primary" : "bg-warning text-dark")">
                                    @(item.Account.IsPaid ? "Đã thanh toán" : "Chưa thanh toán")
                                </span>
                            </td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" href="/Customer/Details/@item.Account.Id">Chi tiết</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
