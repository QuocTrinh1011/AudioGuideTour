<h2 class="mb-4">📊 Dashboard</h2>

<div class="row">

    <div class="col-md-4">
        <div class="card p-4 text-white bg-primary">
            <h5>Total POI</h5>
            <h2>@ViewBag.TotalPoi</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-4 text-white bg-success">
            <h5>Total Visits</h5>
            <h2>@ViewBag.TotalVisit</h2>
        </div>
    </div>

</div>

<br />

<div class="card p-4">
    <h4>🔥 Top POI</h4>
    <ul>
        @foreach (var item in ViewBag.Top)
        {
            <li>POI @item.PoiId - @item.Count lượt</li>
        }
    </ul>
</div>