@model AudioGuideAdmin.Models.LanguageOption

<form method="post" class="card p-4">
    <input asp-for="Id" type="hidden" />
    <div asp-validation-summary="All" class="alert alert-danger"></div>
    <div class="row g-3">
        <div class="col-md-3">
            <label asp-for="Code" class="form-label">Code</label>
            <input asp-for="Code" class="form-control" placeholder="vi-VN" />
            <span asp-validation-for="Code" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Locale" class="form-label">Locale</label>
            <input asp-for="Locale" class="form-control" placeholder="vi-VN" />
            <span asp-validation-for="Locale" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Name" class="form-label">Tên hiển thị</label>
            <input asp-for="Name" class="form-control" placeholder="Tiếng Việt" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="NativeName" class="form-label">Tên bản ngữ</label>
            <input asp-for="NativeName" class="form-control" placeholder="Tiếng Việt / 简体中文" />
            <span asp-validation-for="NativeName" class="text-danger small"></span>
        </div>
        <div class="col-md-2">
            <label asp-for="SortOrder" class="form-label">Thứ tự</label>
            <input asp-for="SortOrder" class="form-control" type="number" />
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <div class="form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Đang sử dụng</label>
            </div>
        </div>
        <div class="col-12 d-flex gap-2">
            <button class="btn btn-primary">Lưu</button>
            <a href="/Language" class="btn btn-outline-secondary">Quay lại</a>
        </div>
    </div>
</form>

<partial name="_ValidationScriptsPartial" />
