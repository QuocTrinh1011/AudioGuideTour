@model AudioGuideAdmin.ViewModels.OwnerPoiDashboardViewModel
@{
    Layout = "~/Views/Shared/_OwnerLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="mb-1">POI của tôi</h2>
        <p class="text-muted mb-0">Quản lý submission chờ duyệt và các POI live thuộc quán của bạn.</p>
    </div>
    @if (string.Equals(Model.Owner.Status, AudioGuideAdmin.Models.ShopOwnerStatus.Approved, StringComparison.OrdinalIgnoreCase))
    {
        <a href="/OwnerPoi/Create" class="btn btn-primary">Tạo submission mới</a>
    }
</div>

@if (!string.Equals(Model.Owner.Status, AudioGuideAdmin.Models.ShopOwnerStatus.Approved, StringComparison.OrdinalIgnoreCase))
{
    <div class="alert @(string.Equals(Model.Owner.Status, AudioGuideAdmin.Models.ShopOwnerStatus.Pending, StringComparison.OrdinalIgnoreCase) ? "alert-warning" : "alert-danger")">
        @if (string.Equals(Model.Owner.Status, AudioGuideAdmin.Models.ShopOwnerStatus.Pending, StringComparison.OrdinalIgnoreCase))
        {
            <span>Tài khoản của bạn đang chờ admin duyệt. Bạn có thể đăng nhập để theo dõi trạng thái, nhưng chưa thể gửi submission mới.</span>
        }
        else
        {
            <span>Tài khoản của bạn đang bị tạm khóa. Hãy liên hệ admin để được hỗ trợ.</span>
        }
    </div>
}

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">Submission của tôi</h4>
                <span class="badge text-bg-secondary">@Model.Submissions.Count</span>
            </div>
            @if (Model.Submissions.Count == 0)
            {
                <div class="text-muted">Bạn chưa có submission nào.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Tên</th>
                                <th>Loại</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Tác vụ</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.Submissions)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.Name</div>
                                    <div class="small text-muted">@item.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                </td>
                                <td>@(item.SubmissionType == "update" ? "Chỉnh sửa" : "Tạo mới")</td>
                                <td><span class="badge text-bg-light border">@item.Status</span></td>
                                <td class="text-end">
                                    @if (item.Status != AudioGuideAdmin.Models.PoiSubmissionStatus.Approved && item.Status != AudioGuideAdmin.Models.PoiSubmissionStatus.Rejected)
                                    {
                                        <a href="/OwnerPoi/Edit/@item.Id" class="btn btn-sm btn-outline-dark">Mở</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Đã khóa</span>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">POI live đã duyệt</h4>
                <span class="badge text-bg-success">@Model.LivePois.Count</span>
            </div>
            @if (Model.LivePois.Count == 0)
            {
                <div class="text-muted">Chưa có POI live nào thuộc quán của bạn.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Tên</th>
                                <th>Danh mục</th>
                                <th class="text-end">Tác vụ</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var poi in Model.LivePois)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@poi.Name</div>
                                    <div class="small text-muted">@poi.Address</div>
                                </td>
                                <td>@poi.Category</td>
                                <td class="text-end">
                                    <form method="post" action="/OwnerPoi/StartUpdate/@poi.Id" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-primary">Tạo submission sửa</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
