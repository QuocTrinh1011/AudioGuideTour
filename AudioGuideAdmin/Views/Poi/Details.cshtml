@model AudioGuideAdmin.Models.Poi

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-1">@Model.Name</h2>
        <div class="text-muted">@Model.Address</div>
    </div>
    <div class="d-flex gap-2">
        <a href="/Poi/Edit/@Model.Id" class="btn btn-warning">Edit</a>
        <a href="/Poi" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card p-4 mb-4">
            <h4 class="mb-3">Thong tin chinh</h4>
            <dl class="row mb-0">
                <dt class="col-sm-4">Category</dt><dd class="col-sm-8">@Model.Category</dd>
                <dt class="col-sm-4">Summary</dt><dd class="col-sm-8">@Model.Summary</dd>
                <dt class="col-sm-4">Radius</dt><dd class="col-sm-8">@Model.Radius m</dd>
                <dt class="col-sm-4">Near Radius</dt><dd class="col-sm-8">@Model.ApproachRadiusMeters m</dd>
                <dt class="col-sm-4">Priority</dt><dd class="col-sm-8">@Model.Priority</dd>
                <dt class="col-sm-4">Trigger</dt><dd class="col-sm-8">@Model.TriggerMode</dd>
                <dt class="col-sm-4">Thuyet minh</dt><dd class="col-sm-8">TTS only</dd>
            </dl>
        </div>
        <div class="card p-4 mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">TTS mac dinh</h4>
                <button type="button" class="btn btn-sm btn-outline-dark" id="preview-detail-tts">Nghe thu</button>
            </div>
            <div class="text-muted small mb-2">Script này được dùng khi translation không có script riêng.</div>
            <div class="border rounded-3 p-3 bg-light-subtle">@Model.TtsScript</div>
        </div>
        <div class="card p-4">
            <h4 class="mb-3">Ban dich</h4>
            <ul class="list-group list-group-flush">
                @foreach (var t in Model.Translations.OrderBy(x => x.Language))
                {
                    <li class="list-group-item px-0">
                        <div class="d-flex justify-content-between gap-3">
                            <div>
                                <div class="fw-semibold">@t.Language - @t.Title</div>
                                <div class="text-muted small">@t.Summary</div>
                            </div>
                            <button type="button"
                                    class="btn btn-sm btn-outline-dark translation-tts-preview"
                                    data-lang="@t.Language"
                                    data-script="@t.TtsScript">
                                Nghe thu
                            </button>
                        </div>
                    </li>
                }
            </ul>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card p-4 mb-4">
            <h4 class="mb-3">Anh POI</h4>
            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Name" style="width:100%;height:280px;object-fit:cover;border-radius:18px;" />
            }
            else
            {
                <div class="text-muted">POI này chưa có ảnh.</div>
            }
        </div>
        <div class="card p-4">
            <h4 class="mb-3">Tour đang sử dụng POI</h4>
            <ul class="list-group list-group-flush">
                @foreach (var stop in Model.TourStops.OrderBy(x => x.SortOrder))
                {
                    <li class="list-group-item px-0">@stop.Tour?.Name (Thu tu @stop.SortOrder)</li>
                }
            </ul>
        </div>
    </div>
</div>
<script>
    let poiDetailsPreviewVoices = [];

    function refreshPoiDetailsPreviewVoices() {
        poiDetailsPreviewVoices = window.speechSynthesis?.getVoices?.() || [];
        return poiDetailsPreviewVoices;
    }

    async function getPreviewVoice(language) {
        let voices = refreshPoiDetailsPreviewVoices();
        if (!voices.length) {
            window.speechSynthesis?.getVoices?.();

            voices = await new Promise((resolve) => {
                let attempts = 0;
                const timer = setInterval(() => {
                    const available = refreshPoiDetailsPreviewVoices();
                    attempts += 1;

                    if (available.length || attempts >= 12) {
                        clearInterval(timer);
                        resolve(available);
                    }
                }, 200);
            });
        }

        const normalized = (language || 'vi-VN').toLowerCase();
        const base = normalized.split('-')[0];

        return voices.find(v => (v.lang || '').toLowerCase() === normalized)
            || voices.find(v => (v.lang || '').toLowerCase().startsWith(base));
    }

    async function previewSpeak(text, language) {
        if (!window.speechSynthesis) {
            alert('Trình duyệt này không hỗ trợ nghe thử TTS.');
            return;
        }

        const utterance = new SpeechSynthesisUtterance(text);
        utterance.lang = language || 'vi-VN';

        const voice = await getPreviewVoice(utterance.lang);
        if (voice) {
            utterance.voice = voice;
        } else if ((utterance.lang || '').toLowerCase().startsWith('vi')) {
            alert('Máy/trình duyệt hiện chưa có voice Tiếng Việt. Hãy cài thêm voice vi-VN để nghe đúng giọng Việt.');
            return;
        }

        window.speechSynthesis.cancel();
        window.speechSynthesis.speak(utterance);
    }

    document.getElementById('preview-detail-tts')?.addEventListener('click', async () => {
        const text = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TtsScript ?? ""));
        if (!text || !text.trim()) {
            alert('POI này chưa có TTS script mặc định.');
            return;
        }

        await previewSpeak(text, @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DefaultLanguage ?? "vi-VN")));
    });

    document.querySelectorAll('.translation-tts-preview').forEach((button) => {
        button.addEventListener('click', async () => {
            const text = button.dataset.script || '';
            if (!text.trim()) {
                alert('Translation này chưa có TTS script.');
                return;
            }

            await previewSpeak(text, button.dataset.lang || 'vi-VN');
        });
    });

    refreshPoiDetailsPreviewVoices();
    window.speechSynthesis?.addEventListener?.('voiceschanged', refreshPoiDetailsPreviewVoices);
</script>
