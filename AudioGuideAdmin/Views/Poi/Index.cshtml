@model IEnumerable<AudioGuideAdmin.Models.Poi>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Quản lý POI</h2>
    <div class="d-flex gap-2">
        <form method="post" action="/Poi/ApplySuggestedImages">
            @Html.AntiForgeryToken()
            <button class="btn btn-outline-primary" type="submit">Gắn ảnh gợi ý</button>
        </form>
        <a href="/Poi/Create" class="btn btn-primary">Thêm POI</a>
    </div>
</div>

<form method="get" class="card p-3 mb-3">
    <div class="row g-2">
        <div class="col-md-8">
            <input type="text" name="search" class="form-control" placeholder="Tìm theo tên, danh mục, địa chỉ..." value="@Context.Request.Query["search"]" />
        </div>
        <div class="col-md-2">
            <select name="activeOnly" class="form-select">
                <option value="">Tất cả</option>
                <option value="true" selected="@(Context.Request.Query["activeOnly"] == "true" ? "selected" : null)">Đang hoạt động</option>
            </select>
        </div>
        <div class="col-md-2">
            <button class="btn btn-dark w-100">Loc</button>
        </div>
    </div>
</form>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Anh</th>
                    <th>POI</th>
                    <th>Danh mục</th>
                    <th>Radius</th>
                    <th>Priority</th>
                    <th>Trigger</th>
                    <th>Trang thai</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Name" style="width:72px;height:54px;object-fit:cover;border-radius:10px;" />
                        }
                        else
                        {
                            <div class="text-muted small">Chưa có anh</div>
                        }
                    </td>
                    <td>
                        <div class="fw-semibold">@item.Name</div>
                        <div class="text-muted small">@item.Address</div>
                    </td>
                    <td>@item.Category</td>
                    <td>@item.Radius m / near @item.ApproachRadiusMeters m</td>
                    <td>@item.Priority</td>
                    <td>@item.TriggerMode</td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge text-bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Inactive</span>
                        }
                    </td>
                    <td class="text-end">
                        <a href="/Poi/Details/@item.Id" class="btn btn-sm btn-outline-dark">Detail</a>
                        <a href="/Poi/Edit/@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a href="/Poi/Delete/@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Xóa POI này?')">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
