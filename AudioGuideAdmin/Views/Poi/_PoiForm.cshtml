@model AudioGuideAdmin.Models.Poi

<form method="post" enctype="multipart/form-data" class="card p-4">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="ImageUrl" type="hidden" />
    <div asp-validation-summary="All" class="alert alert-danger"></div>
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Tên POI</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label class="form-label">Danh mục</label>
            <select asp-for="Category" asp-items="ViewBag.Categories" class="form-select"></select>
            <span asp-validation-for="Category" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label class="form-label">Ngôn ngữ mặc định</label>
            <select asp-for="DefaultLanguage" asp-items="ViewBag.Languages" class="form-select"></select>
            <span asp-validation-for="DefaultLanguage" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Tóm tắt</label>
            <input asp-for="Summary" class="form-control" />
            <span asp-validation-for="Summary" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Địa chỉ</label>
            <input asp-for="Address" class="form-control" />
            <span asp-validation-for="Address" class="text-danger small"></span>
        </div>
        <div class="col-12">
            <label class="form-label">Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label class="form-label">Latitude</label>
            <input asp-for="Latitude" class="form-control" type="number" step="any" />
            <span asp-validation-for="Latitude" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label class="form-label">Longitude</label>
            <input asp-for="Longitude" class="form-control" type="number" step="any" />
            <span asp-validation-for="Longitude" class="text-danger small"></span>
        </div>
        <div class="col-md-2">
            <label class="form-label">Radius</label>
            <input asp-for="Radius" class="form-control" type="number" />
            <span asp-validation-for="Radius" class="text-danger small"></span>
        </div>
        <div class="col-md-2">
            <label class="form-label">Near Radius</label>
            <input asp-for="ApproachRadiusMeters" class="form-control" type="number" />
            <span asp-validation-for="ApproachRadiusMeters" class="text-danger small"></span>
        </div>
        <div class="col-md-2">
            <label class="form-label">Priority</label>
            <input asp-for="Priority" class="form-control" type="number" />
            <span asp-validation-for="Priority" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label class="form-label">Debounce (s)</label>
            <input asp-for="DebounceSeconds" class="form-control" type="number" />
            <span asp-validation-for="DebounceSeconds" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label class="form-label">Cooldown (s)</label>
            <input asp-for="CooldownSeconds" class="form-control" type="number" />
            <span asp-validation-for="CooldownSeconds" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label class="form-label">Trigger mode</label>
            <select asp-for="TriggerMode" class="form-select">
                <option value="both">both</option>
                <option value="enter">enter</option>
                <option value="nearby">nearby</option>
                <option value="manual">manual</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Chế độ thuyết minh</label>
            <input class="form-control" value="TTS only" disabled />
        </div>
        <div class="col-md-8">
            <label class="form-label">Upload ảnh POI</label>
            <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
            <span asp-validation-for="ImageFile" class="text-danger small"></span>
            <div class="form-text">Chỉ cần chọn file rồi bấm Lưu. Admin sẽ lưu vào thư mục dùng chung, API trả về /images/... và mobile app sẽ nhận ảnh mới ngay sau khi tải dữ liệu.</div>
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <div class="d-grid gap-2 w-100">
                <a href="/Image/Upload" target="_blank" class="btn btn-outline-secondary">Thư viện ảnh</a>
                @if (Model.Id > 0)
                {
                    <button class="btn btn-outline-primary"
                            type="submit"
                            formaction="/Poi/ApplySuggestedImage/@Model.Id"
                            formmethod="post"
                            formnovalidate>
                        Gắn ảnh gợi ý
                    </button>
                }
            </div>
        </div>
        <div class="col-md-6">
            <label class="form-label">Map URL</label>
            <input asp-for="MapUrl" class="form-control" />
            <span asp-validation-for="MapUrl" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label class="form-label">Estimated duration (s)</label>
            <input asp-for="EstimatedDurationSeconds" class="form-control" type="number" />
            <span asp-validation-for="EstimatedDurationSeconds" class="text-danger small"></span>
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <div class="form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Đang hoạt động</label>
            </div>
        </div>
        <div class="col-12">
            <label class="form-label">Script TTS mac dinh</label>
            <textarea asp-for="TtsScript" class="form-control" rows="4"></textarea>
            <span asp-validation-for="TtsScript" class="text-danger small"></span>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <small class="text-muted">Nội dung này sẽ được app mobile đọc bằng Text-to-Speech nếu translation không có script riêng.</small>
                <button type="button" class="btn btn-sm btn-outline-dark" id="preview-poi-tts">Nghe thử TTS</button>
            </div>
        </div>
        <div class="col-12">
            <label class="form-label">Audio fallback URL</label>
            <input asp-for="AudioUrl" class="form-control" placeholder="/audio/ten-file.mp3" />
            <span asp-validation-for="AudioUrl" class="text-danger small"></span>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <small class="text-muted">Nếu TTS gặp lỗi, hệ thống có thể dùng file audio dự phòng này.</small>
                <a href="/Audio/Upload" target="_blank" class="btn btn-sm btn-outline-secondary">Mo thu vien audio</a>
            </div>
        </div>
        <div class="col-12">
            <div class="card p-3 bg-light-subtle border-0">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                    <div>
                        <div class="fw-semibold">Preview anh POI</div>
                        <div class="text-muted small">Web admin, API va mobile app se dung chung mot file anh.</div>
                    </div>
                    <div class="text-end">
                        <div class="text-muted small">Đường dẫn hiện tại</div>
                        <code id="poi-image-path" class="small">@Model.ImageUrl</code>
                    </div>
                </div>
                <img id="poi-image-preview"
                     src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "" : Model.ImageUrl)"
                     alt="Preview anh POI"
                     style="max-width:100%;height:240px;object-fit:cover;border-radius:16px;display:@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "none" : "block");" />
                <div id="poi-image-empty" class="text-muted small" style="display:@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "block" : "none");">
                    Chưa có ảnh. Hãy upload file ảnh ở trên, hoặc bấm nút gợi ý nếu muốn dùng ảnh mẫu.
                </div>
            </div>
        </div>
        <div class="col-12">
            <div id="map" style="height:380px;border-radius:18px;"></div>
        </div>
        <div class="col-12 d-flex gap-2">
            <button class="btn btn-primary">Lưu</button>
            <a href="/Poi" class="btn btn-outline-secondary">Quay lại</a>
        </div>
    </div>
</form>

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script>
    const latInput = document.querySelector('[name="Latitude"]');
    const lngInput = document.querySelector('[name="Longitude"]');
    const lat = parseFloat(latInput.value || "10.7618");
    const lng = parseFloat(lngInput.value || "106.6613");
    const map = L.map('map').setView([lat, lng], 16);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
    let marker = L.marker([lat, lng]).addTo(map);

    map.on('click', function (e) {
        latInput.value = e.latlng.lat.toFixed(6);
        lngInput.value = e.latlng.lng.toFixed(6);
        marker.setLatLng(e.latlng);
    });
</script>
<script>
    const imageInput = document.querySelector('[name="ImageUrl"]');
    const imageFileInput = document.querySelector('[name="ImageFile"]');
    const imagePreview = document.getElementById('poi-image-preview');
    const imageEmpty = document.getElementById('poi-image-empty');
    const imagePath = document.getElementById('poi-image-path');

    function refreshImagePreview() {
        const selectedFile = imageFileInput?.files?.[0];
        if (selectedFile) {
            imagePreview.src = URL.createObjectURL(selectedFile);
            imagePreview.style.display = 'block';
            imageEmpty.style.display = 'none';
            imagePath.textContent = `Sẽ tạo tự động sau khi lưu: ${selectedFile.name}`;
            return;
        }

        const value = imageInput?.value?.trim() || '';
        if (!value) {
            imagePreview.style.display = 'none';
            imagePreview.removeAttribute('src');
            imageEmpty.style.display = 'block';
            imagePath.textContent = 'Chưa có';
            return;
        }

        imagePreview.src = value;
        imagePreview.style.display = 'block';
        imageEmpty.style.display = 'none';
        imagePath.textContent = value;
    }

    imageFileInput?.addEventListener('change', refreshImagePreview);
    refreshImagePreview();
</script>
<script>
    let poiPreviewVoices = [];

    function refreshPoiPreviewVoices() {
        poiPreviewVoices = window.speechSynthesis?.getVoices?.() || [];
        return poiPreviewVoices;
    }

    async function getVoicesAsync() {
        let voices = refreshPoiPreviewVoices();
        if (voices.length) {
            return voices;
        }

        window.speechSynthesis?.getVoices?.();

        return await new Promise((resolve) => {
            let attempts = 0;
            const timer = setInterval(() => {
                voices = refreshPoiPreviewVoices();
                attempts += 1;

                if (voices.length || attempts >= 12) {
                    clearInterval(timer);
                    resolve(voices);
                }
            }, 200);
        });
    }

    async function getPreviewVoice(language) {
        const voices = await getVoicesAsync();
        const normalized = (language || 'vi-VN').toLowerCase();
        const base = normalized.split('-')[0];

        return voices.find(v => (v.lang || '').toLowerCase() === normalized)
            || voices.find(v => (v.lang || '').toLowerCase().startsWith(base));
    }

    async function previewSpeak(text, language) {
        if (!window.speechSynthesis) {
            alert('Trình duyệt này không hỗ trợ nghe thử TTS.');
            return;
        }

        const utterance = new SpeechSynthesisUtterance(text);
        utterance.lang = language || 'vi-VN';

        const voice = await getPreviewVoice(utterance.lang);
        if (voice) {
            utterance.voice = voice;
        } else if ((utterance.lang || '').toLowerCase().startsWith('vi')) {
            alert('Máy/trình duyệt hiện chưa có voice Tiếng Việt. Hãy cài thêm voice vi-VN để nghe đúng giọng Việt.');
            return;
        }

        window.speechSynthesis.cancel();
        window.speechSynthesis.speak(utterance);
    }

    document.getElementById('preview-poi-tts')?.addEventListener('click', async () => {
        const textarea = document.querySelector('[name="TtsScript"]');
        const text = textarea?.value?.trim();
        if (!text) {
            alert('Chưa có TTS script để nghe thử.');
            return;
        }

        await previewSpeak(text, document.querySelector('[name="DefaultLanguage"]')?.value || 'vi-VN');
    });

    refreshPoiPreviewVoices();
    window.speechSynthesis?.addEventListener?.('voiceschanged', refreshPoiPreviewVoices);
</script>

<partial name="_ValidationScriptsPartial" />
