@model IEnumerable<AudioGuideAdmin.Models.QRCode>
@{
    var publicQrBaseUrl = (ViewBag.PublicQrBaseUrl as string ?? string.Empty).TrimEnd('/');
    var appEntryDeepLinkUrl = (ViewBag.AppEntryDeepLinkUrl as string ?? string.Empty).Trim();
    var isLocalHost = Uri.TryCreate(publicQrBaseUrl, UriKind.Absolute, out var publicQrUri)
        && (string.Equals(publicQrUri.Host, "localhost", StringComparison.OrdinalIgnoreCase)
            || string.Equals(publicQrUri.Host, "127.0.0.1", StringComparison.OrdinalIgnoreCase));
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-1">Quản lý QR</h2>
        <p class="text-muted mb-0">QR này là QR nội dung thật. Khách có thể quét bằng app hoặc camera điện thoại thông thường để mở trang nghe ngay.</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/QRCode/Create" class="btn btn-primary">Thêm QR</a>
    </div>
</div>

<div class="card p-3 mb-3">
    <div class="row g-3 align-items-center">
        <div class="col-lg-8">
            <div class="fw-semibold mb-1">QR mở app Android ngay</div>
            <div class="text-muted small">
                Mã này tách riêng với các QR nội dung hiện tại. Dùng camera Android quét để mở app trực tiếp, đồng bộ visitor và đưa người dùng vào app ngay.
            </div>
            <div class="small mt-3">
                <div class="fw-semibold">Deep link Android đang mã hóa</div>
                <code>@appEntryDeepLinkUrl</code>
            </div>
            <div class="mt-3 d-flex flex-wrap gap-2">
                <a href="/QRCode/DownloadAppEntryPng" class="btn btn-sm btn-primary">Tải PNG mở app</a>
                <a href="/QRCode/DownloadAppEntrySvg" class="btn btn-sm btn-outline-dark">Tải SVG mở app</a>
            </div>
        </div>
        <div class="col-lg-4 text-center">
            <div class="border rounded-4 bg-white p-2 d-inline-flex align-items-center justify-content-center" style="width:160px;height:160px;">
                <img src="/QRCode/RenderAppEntryPng"
                     alt="QR mở app Android"
                     width="144"
                     height="144"
                     style="max-width:144px;max-height:144px;" />
            </div>
        </div>
    </div>
</div>

<div class="card p-3 mb-3">
    <div class="small">
        <div class="fw-semibold">Public base URL đang dùng cho QR</div>
        <code>@publicQrBaseUrl</code>
        @if (isLocalHost)
        {
            <div class="text-danger mt-2">Base URL hiện là localhost. Muốn khách quét bằng điện thoại ngoài app thì hãy đổi `Qr:PublicBaseUrl` sang IP LAN hoặc domain public.</div>
        }
    </div>
</div>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>QR chuẩn</th>
                    <th>Mã QR</th>
                    <th>POI</th>
                    <th>Ghi chú</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                var publicUrl = $"{publicQrBaseUrl}/QRCode/Open/{Uri.EscapeDataString(item.Code)}";
                <tr>
                    <td style="width:148px;">
                        <div class="border rounded-4 bg-white p-2 d-inline-flex align-items-center justify-content-center" style="width:128px;height:128px;">
                            <img src="/QRCode/RenderPng/@item.Id"
                                 alt="QR @item.Code"
                                 width="112"
                                 height="112"
                                 style="max-width:112px;max-height:112px;" />
                        </div>
                    </td>
                    <td><code>@item.Code</code></td>
                    <td class="fw-semibold">@item.Poi?.Name</td>
                    <td class="text-muted">
                        <div>@item.Note</div>
                        <div class="small mt-2">Link quét: <code>@publicUrl</code></div>
                    </td>
                    <td class="text-end">
                        <a href="/QRCode/DownloadPng/@item.Id" class="btn btn-sm btn-outline-primary">Tải PNG</a>
                        <a href="/QRCode/DownloadSvg/@item.Id" class="btn btn-sm btn-outline-dark">Tải SVG</a>
                        <a href="/QRCode/Open/@item.Code" class="btn btn-sm btn-outline-secondary" target="_blank" rel="noopener noreferrer">Mở link</a>
                        <a href="/QRCode/Edit/@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                        <form method="post" action="/QRCode/Delete/@item.Id" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa QR này?')">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
