@model AudioGuideAdmin.ViewModels.QrPublicPageViewModel
@{
    Layout = "_Layout";
    var narrationText = string.IsNullOrWhiteSpace(Model.NarrationText)
        ? $"{Model.Summary} {Model.Description}".Trim()
        : Model.NarrationText;
    var preferBrowserNarrationOnly = string.Equals(Model.Language, "vi-VN", System.StringComparison.OrdinalIgnoreCase);
}

<style>
    body {
        background: linear-gradient(180deg, #fff8ef, #f5efe6);
    }

    .qr-public-shell {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    .qr-public-card {
        width: min(920px, 100%);
        border-radius: 28px;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 32px 90px rgba(16, 30, 46, 0.12);
    }

    .qr-public-hero {
        background: linear-gradient(135deg, #17324d, #c97732);
        color: #fff;
        padding: 22px 24px;
    }

    .qr-public-content {
        padding: 24px;
    }

    .qr-public-language-switch {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 18px;
    }

    .qr-public-language-pill {
        border-radius: 999px;
        border: 1px solid #d2dfec;
        padding: 8px 14px;
        text-decoration: none;
        color: #17324d;
        background: #f7fafc;
        font-weight: 600;
    }

    .qr-public-language-pill.active {
        background: #17324d;
        color: #ffffff;
        border-color: #17324d;
    }

    .qr-public-image {
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        border-radius: 22px;
        background: #eef3f8;
    }

    .qr-public-note {
        border-radius: 18px;
        background: #f7fafc;
        border: 1px solid #e3ebf3;
        padding: 14px 16px;
    }

    .qr-public-play-status {
        font-size: 0.9rem;
        color: #5f7286;
        margin-top: 12px;
    }
</style>

<div class="qr-public-shell">
    <div class="qr-public-card">
        <div class="qr-public-hero">
            <div class="small text-uppercase opacity-75 mb-2">Audio Guide · QR</div>
            <h1 class="h3 mb-1">@Model.Title</h1>
            <div class="opacity-75">@Model.Note</div>
        </div>

        <div class="qr-public-content">
            @if (Model.AvailableLanguages.Count > 1)
            {
                <div class="qr-public-language-switch">
                    @foreach (var language in Model.AvailableLanguages)
                    {
                        <a class="qr-public-language-pill @(language.IsSelected ? "active" : "")" href="@language.Url">@language.Label</a>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <img class="qr-public-image mb-4" src="@Model.ImageUrl" alt="@Model.Title" />
            }

            <div class="row g-4">
                <div class="col-lg-7">
                    <div class="qr-public-note mb-3">
                        <div class="fw-semibold mb-2">Tóm tắt</div>
                        <div>@Model.Summary</div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.Description))
                    {
                        <div class="qr-public-note mb-3">
                            <div class="fw-semibold mb-2">Giới thiệu</div>
                            <div>@Model.Description</div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(narrationText))
                    {
                        <div class="qr-public-note mb-3">
                            <div class="fw-semibold mb-2">Bản thuyết minh</div>
                            <div class="mb-2">@narrationText</div>
                            <div class="small text-muted">Nguồn: @Model.NarrationSource</div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.Address))
                    {
                        <div class="text-muted small mb-3">Địa chỉ: @Model.Address</div>
                    }

                    <div class="d-flex gap-2 flex-wrap">
                        @if (!string.IsNullOrWhiteSpace(Model.MapUrl))
                        {
                            <a href="@Model.MapUrl" class="btn btn-outline-dark" target="_blank" rel="noopener noreferrer">Mở bản đồ</a>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.DeepLinkUrl))
                        {
                            <a href="@Model.DeepLinkUrl" class="btn btn-primary">Mở trong app</a>
                        }
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="qr-public-note h-100">
                        <div class="fw-semibold mb-2">Nghe ngay</div>
                        @if (!preferBrowserNarrationOnly && !string.IsNullOrWhiteSpace(Model.AudioUrl))
                        {
                            <audio id="poi-audio" controls preload="metadata" playsinline style="width:100%;">
                                <source src="@Model.AudioUrl" />
                            </audio>
                            <button type="button" id="play-audio-button" class="btn btn-primary w-100 mt-3">Phát thuyết minh</button>
                            <div id="play-status" class="qr-public-play-status">Trang sẽ thử phát tự động. Nếu trình duyệt chặn, hãy bấm nút phát.</div>
                        }
                        else
                        {
                            <div class="text-muted">
                                @if (preferBrowserNarrationOnly)
                                {
                                    <text>Tiếng Việt trên trang công khai đang ưu tiên đọc bằng giọng máy để giữ chất lượng thuyết minh ổn định.</text>
                                }
                                else
                                {
                                    <text>Ngôn ngữ này chưa có file audio công khai. Bạn vẫn có thể bấm nút đọc bằng giọng máy để nghe nội dung TTS ngay trên trình duyệt.</text>
                                }
                            </div>
                        }

                        <button type="button" id="speak-browser-button" class="btn btn-outline-dark w-100 mt-3">Đọc bằng giọng máy</button>

                        <div class="small text-muted mt-3">Mã QR: <code>@Model.Code</code></div>
                        <div class="small text-muted">Ngôn ngữ: <code>@Model.LanguageDisplayName (@Model.Language)</code></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const audio = document.getElementById('poi-audio');
    const playButton = document.getElementById('play-audio-button');
    const playStatus = document.getElementById('play-status');
    const browserSpeakButton = document.getElementById('speak-browser-button');
    const speechText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(narrationText));
    const speechLanguage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Language));

    async function tryPlayAudio(auto) {
        if (!audio) {
            return;
        }

        try {
            await audio.play();
            if (playStatus) {
                playStatus.textContent = auto
                    ? 'Âm thanh đã tự phát sau khi mở trang.'
                    : 'Đang phát thuyết minh.';
            }
        } catch (error) {
            if (playStatus) {
                playStatus.textContent = auto
                    ? 'Trình duyệt yêu cầu bạn bấm nút phát để nghe.'
                    : 'Không thể phát tự động. Hãy thử lại hoặc dùng nút đọc bằng giọng máy.';
            }
        }
    }

    if (playButton) {
        playButton.addEventListener('click', () => tryPlayAudio(false));
    }

    if (audio) {
        window.addEventListener('load', () => {
            setTimeout(() => tryPlayAudio(true), 300);
        }, { once: true });
    }

    if (browserSpeakButton) {
        browserSpeakButton.addEventListener('click', () => {
            if (!('speechSynthesis' in window)) {
                alert('Trình duyệt này chưa hỗ trợ đọc bằng giọng máy.');
                return;
            }

            window.speechSynthesis.cancel();
            const utterance = new SpeechSynthesisUtterance(speechText);
            utterance.lang = speechLanguage || 'vi-VN';
            window.speechSynthesis.speak(utterance);
        });
    }
</script>
