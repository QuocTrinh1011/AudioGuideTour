@model AudioGuideAdmin.Models.QRCode
@{
    var poiOptions = ViewBag.PoiOptions as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
        ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var publicQrBaseUrl = (ViewBag.PublicQrBaseUrl as string ?? string.Empty).TrimEnd('/');
    var normalizedCode = (Model.Code ?? string.Empty).Trim().ToUpperInvariant();
    var publicQrUrl = string.IsNullOrWhiteSpace(normalizedCode)
        ? string.Empty
        : $"{publicQrBaseUrl}/QRCode/Open/{Uri.EscapeDataString(normalizedCode)}";
    var isLocalHost = Uri.TryCreate(publicQrBaseUrl, UriKind.Absolute, out var publicQrUri)
        && (string.Equals(publicQrUri.Host, "localhost", StringComparison.OrdinalIgnoreCase)
            || string.Equals(publicQrUri.Host, "127.0.0.1", StringComparison.OrdinalIgnoreCase));
}

<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

<div class="row g-3">
    <div class="col-md-6">
        <label class="form-label">POI</label>
        <select asp-for="PoiId" asp-items="poiOptions" class="form-select"></select>
        <span asp-validation-for="PoiId" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label class="form-label">Mã QR</label>
        <input asp-for="Code" class="form-control" placeholder="VD: BUS-VK-001" />
        <span asp-validation-for="Code" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label class="form-label">Ghi chú</label>
        <textarea asp-for="Note" class="form-control" rows="3" placeholder="VD: Trạm xe buýt phường Khánh Hội"></textarea>
    </div>
    <div class="col-lg-6">
        <div class="card border-0 bg-light-subtle p-3 h-100">
            <div class="fw-semibold mb-2">Xem trước QR chuẩn</div>
            <div class="text-muted small mb-3">QR sẽ mã hóa một đường dẫn công khai để camera điện thoại thông thường cũng mở được trang nghe nội dung.</div>
            <div class="border rounded-4 bg-white p-3 d-inline-flex align-items-center justify-content-center" style="width:220px;height:220px;">
                <img id="qr-preview-image"
                     src="@(string.IsNullOrWhiteSpace(normalizedCode) ? "" : $"/QRCode/RenderPngByCode?code={Uri.EscapeDataString(normalizedCode)}")"
                     alt="QR preview"
                     width="180"
                     height="180"
                     style="max-width:180px;max-height:180px;display:@(string.IsNullOrWhiteSpace(normalizedCode) ? "none" : "block");" />
                <div id="qr-preview-empty" class="text-muted small" style="display:@(string.IsNullOrWhiteSpace(normalizedCode) ? "block" : "none");">
                    Nhập mã QR ở trên để xem trước ảnh QR.
                </div>
            </div>
            <div class="mt-3 small">
                <div class="fw-semibold mb-1">Đường dẫn công khai trong QR</div>
                <code id="qr-preview-code">@(string.IsNullOrWhiteSpace(publicQrUrl) ? "Chưa có" : publicQrUrl)</code>
                @if (isLocalHost)
                {
                    <div class="text-danger mt-2">
                        `Qr:PublicBaseUrl` đang là localhost. Điện thoại bên ngoài sẽ không mở được mã này cho tới khi bạn đổi sang IP LAN hoặc domain public.
                    </div>
                }
            </div>
            <div class="mt-3 d-flex gap-2 flex-wrap">
                <a id="qr-download-link"
                   href="@(string.IsNullOrWhiteSpace(normalizedCode) ? "#" : $"/QRCode/RenderPngByCode?code={Uri.EscapeDataString(normalizedCode)}")"
                   class="btn btn-outline-dark btn-sm @(string.IsNullOrWhiteSpace(normalizedCode) ? "disabled" : "")"
                   download="@(string.IsNullOrWhiteSpace(normalizedCode) ? "qr.png" : $"{normalizedCode}.png")">
                    Tải QR PNG
                </a>
                <a id="qr-open-link"
                   href="@(string.IsNullOrWhiteSpace(publicQrUrl) ? "#" : publicQrUrl)"
                   class="btn btn-outline-primary btn-sm @(string.IsNullOrWhiteSpace(publicQrUrl) ? "disabled" : "")"
                   target="_blank"
                   rel="noopener noreferrer">
                    Mở trang công khai
                </a>
            </div>
        </div>
    </div>
</div>

<div class="mt-4 d-flex gap-2">
    <button class="btn btn-primary" type="submit">Lưu QR</button>
    <a href="/QRCode" class="btn btn-outline-secondary">Quay lại</a>
</div>

<script>
    const qrCodeInput = document.querySelector('[name="Code"]');
    const qrPreviewImage = document.getElementById('qr-preview-image');
    const qrPreviewEmpty = document.getElementById('qr-preview-empty');
    const qrPreviewCode = document.getElementById('qr-preview-code');
    const qrDownloadLink = document.getElementById('qr-download-link');
    const qrOpenLink = document.getElementById('qr-open-link');
    const publicQrBaseUrl = '@publicQrBaseUrl';

    function refreshQrPreview() {
        const raw = qrCodeInput?.value?.trim().toUpperCase() || '';
        const payloadUrl = raw ? `${publicQrBaseUrl}/QRCode/Open/${encodeURIComponent(raw)}` : '';
        qrPreviewCode.textContent = payloadUrl || 'Chưa có';

        if (!raw) {
            qrPreviewImage.style.display = 'none';
            qrPreviewImage.removeAttribute('src');
            qrPreviewEmpty.style.display = 'block';
            qrDownloadLink.classList.add('disabled');
            qrDownloadLink.setAttribute('href', '#');
            qrDownloadLink.setAttribute('download', 'qr.png');
            qrOpenLink.classList.add('disabled');
            qrOpenLink.setAttribute('href', '#');
            return;
        }

        const previewUrl = `/QRCode/RenderPngByCode?code=${encodeURIComponent(raw)}`;
        qrPreviewImage.src = previewUrl;
        qrPreviewImage.style.display = 'block';
        qrPreviewEmpty.style.display = 'none';
        qrDownloadLink.classList.remove('disabled');
        qrDownloadLink.setAttribute('href', previewUrl);
        qrDownloadLink.setAttribute('download', `${raw}.png`);
        qrOpenLink.classList.remove('disabled');
        qrOpenLink.setAttribute('href', payloadUrl);
    }

    qrCodeInput?.addEventListener('input', refreshQrPreview);
    refreshQrPreview();
</script>
