@model AudioGuideAdmin.Controllers.SampleDataSummaryViewModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Du lieu mau</h2>
        <p class="text-muted mb-0">Nap bo du lieu demo cho danh muc, POI, translation, tour, tracking, visit va geofence trigger.</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3"><div class="card p-3"><div class="text-muted">Danh muc</div><div class="fs-3 fw-bold">@Model.CategoryCount</div></div></div>
    <div class="col-md-6 col-xl-3"><div class="card p-3"><div class="text-muted">POI</div><div class="fs-3 fw-bold">@Model.PoiCount</div></div></div>
    <div class="col-md-6 col-xl-3"><div class="card p-3"><div class="text-muted">Translation</div><div class="fs-3 fw-bold">@Model.TranslationCount</div></div></div>
    <div class="col-md-6 col-xl-3"><div class="card p-3"><div class="text-muted">Tour</div><div class="fs-3 fw-bold">@Model.TourCount</div></div></div>
    <div class="col-md-6 col-xl-4"><div class="card p-3"><div class="text-muted">Tracking</div><div class="fs-3 fw-bold">@Model.TrackingCount</div></div></div>
    <div class="col-md-6 col-xl-4"><div class="card p-3"><div class="text-muted">Visit</div><div class="fs-3 fw-bold">@Model.VisitCount</div></div></div>
    <div class="col-md-6 col-xl-4"><div class="card p-3"><div class="text-muted">Trigger</div><div class="fs-3 fw-bold">@Model.TriggerCount</div></div></div>
</div>

<div class="card p-4">
    <h4 class="mb-3">Bo du lieu demo se them</h4>
    <ul class="mb-4">
        <li>4 danh muc mau cho pho am thuc Vinh Khanh.</li>
        <li>3 POI mau kem TTS script va hinh anh.</li>
        <li>Nhieu translation mau cho vi-VN va en-US.</li>
        <li>1 tour mau va cac diem dung tour.</li>
        <li>Tracking, visit history va geofence trigger demo de dashboard va analytics hien thi du lieu ngay.</li>
    </ul>

    <form method="post" asp-action="Seed">
        @Html.AntiForgeryToken()
        <button class="btn btn-primary">Nap du lieu mau cho toan bo web</button>
    </form>
</div>
