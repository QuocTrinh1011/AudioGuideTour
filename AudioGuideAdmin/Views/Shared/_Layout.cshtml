<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Audio Guide Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { background: #f4f6fb; font-family: "Segoe UI", sans-serif; }
        .sidebar { min-height: 100vh; background: linear-gradient(180deg, #17324d, #0f1f31); color: #fff; padding: 24px 18px; }
        .sidebar a { color: #d7e5f3; display: block; padding: 10px 12px; border-radius: 10px; text-decoration: none; margin-bottom: 8px; }
        .sidebar a:hover { background: rgba(255,255,255,.1); color: #fff; }
        .content { padding: 24px; }
        .card { border: 0; border-radius: 18px; box-shadow: 0 18px 40px rgba(14, 31, 53, .08); }
        .form-control, .form-select { border-radius: 12px; }
        .btn { border-radius: 12px; }
        .badge-soft { background: #edf3ff; color: #17324d; }
    </style>
</head>
<body>
    @if (ViewBag.HideAdminChrome == true)
    {
        @RenderBody()
    }
    else
    {
        <div class="container-fluid">
            <div class="row">
                <aside class="col-lg-2 sidebar">
                    <h4 class="mb-4">Audio Guide CMS</h4>
                    <a href="/Dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
                    <a href="/Language"><i class="bi bi-translate me-2"></i> Ngôn ngữ</a>
                    <a href="/Category"><i class="bi bi-tags me-2"></i> Danh mục</a>
                    <a href="/Poi"><i class="bi bi-geo-alt me-2"></i> POI</a>
                    <a href="/Poi/Map"><i class="bi bi-map me-2"></i> Map</a>
                    <a href="/Translation"><i class="bi bi-translate me-2"></i> Translation</a>
                    <a href="/Audio/Upload"><i class="bi bi-mic me-2"></i> Audio</a>
                    <a href="/QRCode"><i class="bi bi-qr-code me-2"></i> QR</a>
                    <a href="/Tour"><i class="bi bi-signpost-split me-2"></i> Tour</a>
                    <a href="/Visitor"><i class="bi bi-phone me-2"></i> Visitor</a>
                    <a href="/Analytics"><i class="bi bi-bar-chart-line me-2"></i> Analytics</a>
                    <a href="/Tracking"><i class="bi bi-activity me-2"></i> Tracking</a>
                    <a href="/Auth/Logout" class="mt-4 btn btn-danger w-100">Logout</a>
                </aside>
                <main class="col-lg-10 content">
                    @if (TempData["Success"] is string successMessage)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @successMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (TempData["Error"] is string errorMessage)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @errorMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @RenderBody()
                </main>
            </div>
        </div>
    }
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
