<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: #f5f6fa;
        }

        .sidebar {
            height: 100vh;
            background: #2f3640;
            color: white;
            padding: 20px;
        }

            .sidebar a {
                display: block;
                color: #dcdde1;
                padding: 10px;
                border-radius: 8px;
                margin-bottom: 10px;
                text-decoration: none;
            }

                .sidebar a:hover {
                    background: #40739e;
                    color: white;
                }

        .content {
            padding: 20px;
        }

        .card {
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .btn {
            border-radius: 10px;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">

            <!-- Sidebar -->
            <div class="col-md-2 sidebar">
                <h4>🎧 Admin</h4>

                <a href="/Dashboard"><i class="bi bi-bar-chart"></i> Dashboard</a>
                <a href="/Poi"><i class="bi bi-geo-alt"></i> POI</a>
                <a href="/Poi/Map"><i class="bi bi-map"></i> Map</a>
                <a href="/Translation"><i class="bi bi-translate"></i> Translation</a>
                <a href="/Audio/Upload"><i class="bi bi-mic"></i> Audio</a>
                <a href="/Tracking"><i class="bi bi-graph-up"></i> Tracking</a>
                <a href="/Auth/Logout" class="btn btn-danger">Logout</a>
            </div>

            <!-- Content -->
            <div class="col-md-10 content">
                @RenderBody()
            </div>

        </div>
    </div>
</body>
</html>