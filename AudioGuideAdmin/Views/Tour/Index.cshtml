@model IEnumerable<AudioGuideAdmin.Models.Tour>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Quản lý tour</h2>
    <a href="/Tour/Create" class="btn btn-primary">Thêm tour</a>
</div>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Tour</th><th>Ngôn ngữ mặc định</th><th>Điểm dừng</th><th>Thời lượng</th><th>Trạng thái</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@item.Name</div>
                        <div class="text-muted small">@item.Description</div>
                        @if (item.Translations.Any())
                        {
                            <div class="small text-muted mt-1">Có @item.Translations.Count bản dịch phụ</div>
                        }
                    </td>
                    <td>@item.Language</td>
                    <td>@item.Stops.Count</td>
                    <td>@item.EstimatedDurationMinutes phút</td>
                    <td>@(item.IsActive ? "Đang hoạt động" : "Tạm ẩn")</td>
                    <td class="text-end">
                        <a href="/Tour/Edit/@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                        <form method="post" action="/Tour/Delete/@item.Id" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa tour này?')">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
