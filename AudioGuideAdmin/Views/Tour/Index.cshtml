@model IEnumerable<AudioGuideAdmin.Models.Tour>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Quan ly tour</h2>
    <a href="/Tour/Create" class="btn btn-primary">Them tour</a>
</div>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Tour</th><th>Language</th><th>Stops</th><th>Duration</th><th>Status</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@item.Name</div>
                        <div class="text-muted small">@item.Description</div>
                    </td>
                    <td>@item.Language</td>
                    <td>@item.Stops.Count</td>
                    <td>@item.EstimatedDurationMinutes min</td>
                    <td>@(item.IsActive ? "Active" : "Inactive")</td>
                    <td class="text-end">
                        <a href="/Tour/Edit/@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a href="/Tour/Delete/@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Xoa tour nay?')">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
