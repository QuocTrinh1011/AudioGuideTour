@model AudioGuideAdmin.ViewModels.TourFormViewModel

<form method="post" enctype="multipart/form-data" class="card p-4">
    @Html.AntiForgeryToken()
    <input asp-for="Tour.Id" type="hidden" />
    <input asp-for="Tour.CoverImageUrl" type="hidden" />
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Ten tour</label>
            <input asp-for="Tour.Name" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Language</label>
            <input asp-for="Tour.Language" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Duration (min)</label>
            <input asp-for="Tour.EstimatedDurationMinutes" class="form-control" />
        </div>
        <div class="col-12">
            <label class="form-label">Description</label>
            <textarea asp-for="Tour.Description" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-md-8">
            <label class="form-label">Upload cover image</label>
            <input asp-for="CoverImageFile" class="form-control" type="file" accept="image/*" />
            <div class="form-text">Chon file cover, he thong se tu luu vao /images va mobile app se lay anh tour tu dong.</div>
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <div class="d-grid gap-2 w-100">
                <a href="/Image/Upload" target="_blank" class="btn btn-outline-secondary">Thu vien anh</a>
            </div>
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <div class="form-check form-switch">
                <input asp-for="Tour.IsActive" class="form-check-input" />
                <label asp-for="Tour.IsActive" class="form-check-label">Dang hoat dong</label>
            </div>
        </div>
        <div class="col-12">
            <div class="card p-3 bg-light-subtle border-0">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                    <div>
                        <div class="fw-semibold">Preview cover tour</div>
                        <div class="text-muted small">Cover nay se hien o admin va mobile app.</div>
                    </div>
                    <div class="text-end">
                        <div class="text-muted small">Duong dan hien tai</div>
                        <code id="tour-cover-path" class="small">@Model.Tour.CoverImageUrl</code>
                    </div>
                </div>
                <img id="tour-cover-preview"
                     src="@(string.IsNullOrWhiteSpace(Model.Tour.CoverImageUrl) ? "" : Model.Tour.CoverImageUrl)"
                     alt="Preview cover tour"
                     style="max-width:100%;height:240px;object-fit:cover;border-radius:16px;display:@(string.IsNullOrWhiteSpace(Model.Tour.CoverImageUrl) ? "none" : "block");" />
                <div id="tour-cover-empty" class="text-muted small" style="display:@(string.IsNullOrWhiteSpace(Model.Tour.CoverImageUrl) ? "block" : "none");">
                    Chua co cover. Hay upload file cover o tren.
                </div>
            </div>
        </div>
        <div class="col-12">
            <label class="form-label">Thu tu POI trong tour</label>
            <input asp-for="StopPoiIds" class="form-control" placeholder="Vi du: 1,5,2,8" />
            <div class="form-text">Nhap ID POI cach nhau bang dau phay theo dung thu tu tour.</div>
        </div>
        <div class="col-12">
            <div class="d-flex flex-wrap gap-2">
                @foreach (var poi in Model.PoiOptions)
                {
                    <span class="badge badge-soft">@poi.Text</span>
                }
            </div>
        </div>
        <div class="col-12 d-flex gap-2">
            <button class="btn btn-primary">Luu</button>
            <a href="/Tour" class="btn btn-outline-secondary">Quay lai</a>
        </div>
    </div>
</form>

<script>
    const coverInput = document.querySelector('[name="Tour.CoverImageUrl"]');
    const coverFileInput = document.querySelector('[name="CoverImageFile"]');
    const coverPreview = document.getElementById('tour-cover-preview');
    const coverEmpty = document.getElementById('tour-cover-empty');
    const coverPath = document.getElementById('tour-cover-path');

    function refreshCoverPreview() {
        const selectedFile = coverFileInput?.files?.[0];
        if (selectedFile) {
            coverPreview.src = URL.createObjectURL(selectedFile);
            coverPreview.style.display = 'block';
            coverEmpty.style.display = 'none';
            coverPath.textContent = `Se tao tu dong sau khi luu: ${selectedFile.name}`;
            return;
        }

        const value = coverInput?.value?.trim() || '';
        if (!value) {
            coverPreview.style.display = 'none';
            coverPreview.removeAttribute('src');
            coverEmpty.style.display = 'block';
            coverPath.textContent = 'Chua co';
            return;
        }

        coverPreview.src = value;
        coverPreview.style.display = 'block';
        coverEmpty.style.display = 'none';
        coverPath.textContent = value;
    }

    coverFileInput?.addEventListener('change', refreshCoverPreview);
    refreshCoverPreview();
</script>
