@model IEnumerable<AudioGuideAdmin.Models.PoiTranslation>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Bản dịch đa ngôn ngữ</h2>
    <a href="/Translation/Create" class="btn btn-primary">Thêm bản dịch</a>
</div>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>POI</th>
                    <th>Language</th>
                    <th>Title</th>
                    <th>Voice</th>
                    <th>TTS</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Poi?.Name</td>
                    <td>@item.Language</td>
                    <td>
                        <div class="fw-semibold">@item.Title</div>
                        <div class="text-muted small">@item.Summary</div>
                    </td>
                    <td class="small">@item.VoiceName</td>
                    <td class="small text-truncate" style="max-width: 320px;">@item.TtsScript</td>
                    <td>
                        @if (item.IsPublished)
                        {
                            <span class="badge text-bg-success">Published</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Draft</span>
                        }
                    </td>
                    <td class="text-end">
                        <a href="/Translation/Edit/@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <form method="post" action="/Translation/Delete/@item.Id" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa bản dịch này?')">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
