@model AudioGuideAdmin.Models.PoiTranslation

<form method="post" class="card p-4">
    <input asp-for="Id" type="hidden" />
    <div asp-validation-summary="All" class="alert alert-danger"></div>
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">POI</label>
            <select asp-for="PoiId" asp-items="ViewBag.Pois" class="form-select"></select>
            <span asp-validation-for="PoiId" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label class="form-label">Language</label>
            <select asp-for="Language" asp-items="ViewBag.Languages" class="form-select"></select>
            <span asp-validation-for="Language" class="text-danger small"></span>
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <div class="form-check form-switch">
                <input asp-for="IsPublished" class="form-check-input" />
                <label asp-for="IsPublished" class="form-check-label">Published</label>
            </div>
        </div>
        <div class="col-md-6">
            <label class="form-label">Title</label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Summary</label>
            <input asp-for="Summary" class="form-control" />
            <span asp-validation-for="Summary" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Voice name</label>
            <input asp-for="VoiceName" class="form-control" />
            <span asp-validation-for="VoiceName" class="text-danger small"></span>
        </div>
        <div class="col-12">
            <label class="form-label">TTS Script</label>
            <textarea asp-for="TtsScript" class="form-control" rows="3"></textarea>
            <span asp-validation-for="TtsScript" class="text-danger small"></span>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <small class="text-muted">He thong hien dang dung TTS, khong can nhap audio URL.</small>
                <button type="button" class="btn btn-sm btn-outline-dark" id="preview-translation-tts">Nghe thu TTS</button>
            </div>
        </div>
        <div class="col-12">
            <label class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="6"></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>
        <div class="col-12 d-flex gap-2">
            <button class="btn btn-primary">Luu</button>
            <a href="/Translation" class="btn btn-outline-secondary">Quay lai</a>
        </div>
    </div>
</form>
<script>
    document.getElementById('preview-translation-tts')?.addEventListener('click', () => {
        const textarea = document.querySelector('[name="TtsScript"]');
        const text = textarea?.value?.trim();
        if (!text) {
            alert('Chua co TTS script de nghe thu.');
            return;
        }

        window.speechSynthesis.cancel();
        const utterance = new SpeechSynthesisUtterance(text);
        utterance.lang = document.querySelector('[name="Language"]')?.value || 'vi-VN';
        window.speechSynthesis.speak(utterance);
    });
</script>

<partial name="_ValidationScriptsPartial" />
