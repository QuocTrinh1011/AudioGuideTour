@model IEnumerable<AudioGuideAdmin.ViewModels.VisitorSummaryViewModel>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-1">Quan ly visitor mobile</h2>
        <p class="text-muted mb-0">Theo doi thiet bi, nguoi dung an danh va cac tuy chon auto-play/background tracking.</p>
    </div>
</div>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Visitor</th>
                    <th>Ngon ngu</th>
                    <th>Auto play</th>
                    <th>Background</th>
                    <th>Lan cuoi</th>
                    <th>Tracking</th>
                    <th>Visit</th>
                    <th>Trigger</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@item.Visitor.DisplayName</div>
                        <div class="small text-muted"><code>@item.Visitor.DeviceId</code></div>
                    </td>
                    <td><span class="badge badge-soft">@item.Visitor.Language</span></td>
                    <td>@(item.Visitor.AllowAutoPlay ? "Bat" : "Tat")</td>
                    <td>@(item.Visitor.AllowBackgroundTracking ? "Bat" : "Tat")</td>
                    <td>@item.Visitor.LastSeenAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@item.TrackingCount</td>
                    <td>@item.VisitCount</td>
                    <td>@item.TriggerCount</td>
                    <td class="text-end">
                        <a href="/Visitor/Edit/@item.Visitor.Id" class="btn btn-sm btn-warning">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
