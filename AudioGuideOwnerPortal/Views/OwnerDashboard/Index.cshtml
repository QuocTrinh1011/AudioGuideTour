@model OwnerDashboardViewModel
@{
    Layout = "~/Views/Shared/_OwnerLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="mb-1">Dashboard owner</h2>
        <p class="text-muted mb-0">Theo dõi hiệu quả nội dung của quán bạn theo dữ liệu POI live hiện tại.</p>
    </div>
    <a href="/OwnerPoi" class="btn btn-outline-secondary">Mở POI của tôi</a>
</div>

@if (!string.Equals(Model.Owner.Status, ShopOwnerStatus.Approved, StringComparison.OrdinalIgnoreCase))
{
    <div class="alert @(string.Equals(Model.Owner.Status, ShopOwnerStatus.Pending, StringComparison.OrdinalIgnoreCase) ? "alert-warning" : "alert-danger") mb-4">
        @if (string.Equals(Model.Owner.Status, ShopOwnerStatus.Pending, StringComparison.OrdinalIgnoreCase))
        {
            <span>Tài khoản của bạn vẫn đang chờ admin duyệt. Dashboard vẫn hiển thị dữ liệu hiện có, nhưng bạn chưa thể gửi submission mới.</span>
        }
        else
        {
            <span>Tài khoản của bạn hiện đang bị tạm khóa. Hãy liên hệ admin để được hỗ trợ.</span>
        }
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-lg-3 col-md-6">
        <div class="card p-4 h-100">
            <div class="text-muted small mb-2">POI live</div>
            <div class="display-6 fw-semibold">@Model.LivePoiCount</div>
            <div class="small text-muted mt-2">@Model.ActivePoiCount đang hoạt động</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="card p-4 h-100">
            <div class="text-muted small mb-2">Submission đang xử lý</div>
            <div class="display-6 fw-semibold">@Model.PendingSubmissionCount</div>
            <div class="small text-muted mt-2">@Model.DraftSubmissionCount draft, @Model.ChangesRequestedCount cần sửa</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="card p-4 h-100">
            <div class="text-muted small mb-2">Tổng lượt nghe</div>
            <div class="display-6 fw-semibold">@Model.TotalListenCount</div>
            <div class="small text-muted mt-2">@Model.UniqueVisitorCount visitor duy nhất</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="card p-4 h-100">
            <div class="text-muted small mb-2">Nghe trung bình</div>
            <div class="display-6 fw-semibold">@($"{Model.AverageListenSeconds:0.#}s")</div>
            <div class="small text-muted mt-2">POI nổi bật: @Model.TopPoiName</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-7">
        <div class="card p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">Top POI của quán</h4>
                <span class="badge text-bg-light border">@Model.TopPois.Count mục</span>
            </div>
            @if (Model.TopPois.Count == 0)
            {
                <div class="text-muted">Chưa có lượt nghe nào để thống kê.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>POI</th>
                                <th>Danh mục</th>
                                <th>Lượt nghe</th>
                                <th>Avg</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.TopPois)
                        {
                            <tr>
                                <td class="fw-semibold">@item.PoiName</td>
                                <td>@item.Category</td>
                                <td>@item.ListenCount</td>
                                <td>@($"{item.AverageListenSeconds:0.#}s")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="col-xl-5">
        <div class="card p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">Ngôn ngữ được dùng</h4>
                <span class="badge text-bg-light border">@Model.TopLanguageLabel</span>
            </div>
            @if (Model.LanguageUsage.Count == 0)
            {
                <div class="text-muted">Chưa có dữ liệu ngôn ngữ.</div>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var item in Model.LanguageUsage)
                    {
                        <div>
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <div class="fw-semibold">@item.Label</div>
                                <div class="small text-muted">@item.ListenCount lượt</div>
                            </div>
                            <div class="progress" role="progressbar" aria-label="@item.Label" aria-valuenow="@item.Percentage" aria-valuemin="0" aria-valuemax="100" style="height: 10px;">
                                <div class="progress-bar" style="width:@item.Percentage%"></div>
                            </div>
                            <div class="small text-muted mt-1">@item.Percentage%</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-xl-7">
        <div class="card p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">Sức khỏe nội dung</h4>
                <span class="badge text-bg-warning">@(Model.ContentHealth.MissingTranslationPoiCount + Model.ContentHealth.MissingAudioFallbackPoiCount + Model.ContentHealth.MissingImagePoiCount + Model.ContentHealth.MissingDefaultTtsPoiCount)</span>
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="rounded-4 bg-light p-3 h-100">
                        <div class="text-muted small mb-1">POI thiếu bản dịch phụ</div>
                        <div class="h3 mb-0">@Model.ContentHealth.MissingTranslationPoiCount</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="rounded-4 bg-light p-3 h-100">
                        <div class="text-muted small mb-1">POI thiếu audio fallback mặc định</div>
                        <div class="h3 mb-0">@Model.ContentHealth.MissingAudioFallbackPoiCount</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="rounded-4 bg-light p-3 h-100">
                        <div class="text-muted small mb-1">POI thiếu ảnh</div>
                        <div class="h3 mb-0">@Model.ContentHealth.MissingImagePoiCount</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="rounded-4 bg-light p-3 h-100">
                        <div class="text-muted small mb-1">POI thiếu TTS mặc định</div>
                        <div class="h3 mb-0">@Model.ContentHealth.MissingDefaultTtsPoiCount</div>
                    </div>
                </div>
            </div>
            <div class="small text-muted mt-3">
                @Model.ContentHealth.SingleLanguagePoiCount POI hiện mới chỉ có ngôn ngữ mặc định.
            </div>
        </div>
    </div>

    <div class="col-xl-5">
        <div class="card p-4 h-100">
            <h4 class="mb-3">Tóm tắt workflow</h4>
            <div class="d-flex flex-column gap-3">
                <div class="rounded-4 bg-light p-3">
                    <div class="text-muted small mb-1">Draft</div>
                    <div class="h4 mb-0">@Model.DraftSubmissionCount</div>
                </div>
                <div class="rounded-4 bg-light p-3">
                    <div class="text-muted small mb-1">Chờ duyệt</div>
                    <div class="h4 mb-0">@Model.PendingSubmissionCount</div>
                </div>
                <div class="rounded-4 bg-light p-3">
                    <div class="text-muted small mb-1">Cần chỉnh sửa</div>
                    <div class="h4 mb-0">@Model.ChangesRequestedCount</div>
                </div>
                <div class="rounded-4 bg-light p-3">
                    <div class="text-muted small mb-1">Đã duyệt</div>
                    <div class="h4 mb-0">@Model.ApprovedSubmissionCount</div>
                </div>
            </div>
        </div>
    </div>
</div>
