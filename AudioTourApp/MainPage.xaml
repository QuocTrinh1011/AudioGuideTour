<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AudioTourApp.MainPage"
             Title="Audio Tour">
    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="16">
            <Label Text="Audio Tour App" FontSize="28" FontAttributes="Bold" />
            <Label Text="App mobile Android cho theo doi GPS, geofence, auto narration va map view." TextColor="#5D7287" />

            <Border Stroke="#D7E1EC" BackgroundColor="White" StrokeShape="RoundRectangle 18" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="API Base URL" FontAttributes="Bold" />
                    <Entry Text="{Binding ApiBaseUrl}" Placeholder="http://10.0.2.2:5000" />
                    <HorizontalStackLayout Spacing="10">
                        <Button Text="Bootstrap" Clicked="OnBootstrapClicked" />
                        <Button Text="Bat / Tat tracking" Clicked="OnToggleTrackingClicked" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding Status}" TextColor="#1F5FAA" />
                    <Label Text="{Binding CurrentLocation}" />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="#D7E1EC" BackgroundColor="White" StrokeShape="RoundRectangle 18" Padding="0">
                <WebView HeightRequest="340">
                    <WebView.Source>
                        <HtmlWebViewSource Html="{Binding MapHtml}" />
                    </WebView.Source>
                </WebView>
            </Border>

            <Border Stroke="#D7E1EC" BackgroundColor="White" StrokeShape="RoundRectangle 18" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="POI gan nhat" FontSize="20" FontAttributes="Bold" />
                    <CollectionView ItemsSource="{Binding NearbyPois}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="#E8EEF5" StrokeShape="RoundRectangle 14" Padding="12" Margin="0,0,0,10">
                                    <VerticalStackLayout>
                                        <Label Text="{Binding Title}" FontAttributes="Bold" />
                                        <Label Text="{Binding Summary}" TextColor="#5D7287" />
                                        <Label Text="{Binding DistanceMeters, StringFormat='Khoang cach: {0:F0}m'}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="#D7E1EC" BackgroundColor="White" StrokeShape="RoundRectangle 18" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Tour dang san sang" FontSize="20" FontAttributes="Bold" />
                    <CollectionView ItemsSource="{Binding Tours}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" Padding="0,6">
                                    <VerticalStackLayout>
                                        <Label Text="{Binding Name}" FontAttributes="Bold" />
                                        <Label Text="{Binding Description}" TextColor="#5D7287" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1" Text="{Binding EstimatedDurationMinutes, StringFormat='{}{0} min'}" VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
