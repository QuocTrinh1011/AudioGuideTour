        function renderInventory() {
            const host = document.getElementById("inventoryGroups");
            const groups = [...new Set(features.map(item => item.module))];

            host.innerHTML = groups.map(group => {
                const rows = features.filter(item => item.module === group);
                const tableRows = rows.map(item => `
                    <tr>
                        <td><strong>${item.id}</strong></td>
                        <td>${item.title}</td>
                        <td>${item.actor}</td>
                        <td>${item.entry}</td>
                        <td>${item.source}</td>
                        <td><span class="status ${item.status}">${statusLabel(item.status)}</span></td>
                    </tr>
                `).join("");

                return `
                    <div>
                        <div class="inventory-head">
                            <div>
                                <h3>${group}</h3>
                                <div class="mini-meta">${moduleDescriptions[group]}</div>
                            </div>
                            <span class="status ok">${rows.length} sequence</span>
                        </div>
                        <div class="table-wrap">
                            <table>
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Chб»©c nДѓng</th>
                                        <th>Actor chГ­nh</th>
                                        <th>Дђiб»ѓm vГ o</th>
                                        <th>Trace tб»›i code</th>
                                        <th>TrбєЎng thГЎi</th>
                                    </tr>
                                </thead>
                                <tbody>${tableRows}</tbody>
                            </table>
                        </div>
                    </div>
                `;
            }).join("");

            host.querySelectorAll("thead tr").forEach(row => {
                row.innerHTML = `
                    <th>ID</th>
                    <th>Sequence</th>
                    <th>Primary actor</th>
                    <th>PRD entry</th>
                    <th>PRD source</th>
                    <th>Type</th>
                `;
            });
        }

        function renderToolbar(active = "All") {
            const groups = [...new Set(features.map(item => item.module))];
            const items = ["All", ...groups];
            const counts = Object.fromEntries(
                items.map(item => [item, item === "All" ? features.length : features.filter(x => x.module === item).length])
            );
            const host = document.getElementById("sequenceToolbar");
            host.innerHTML = items.map(item => `
                <button class="toolbar-btn ${item === active ? "active" : ""}" data-filter="${item}">
                    ${item} (${counts[item]})
                </button>
            `).join("");

            host.querySelectorAll("[data-filter]").forEach(button => {
                button.addEventListener("click", () => {
                    const filter = button.getAttribute("data-filter") || "All";
                    renderToolbar(filter);
                    renderSequenceCards(filter);
                });
            });
        }

        function renderSequenceCards(filter = "All") {
            const host = document.getElementById("sequenceGrid");
            const rows = filter === "All" ? features : features.filter(item => item.module === filter);

            host.innerHTML = rows.map(item => `
                <div class="sequence-card">
                    <div class="idline">
                        <strong>${item.id}</strong>
                        <span class="status ${item.status}">${statusLabel(item.status)}</span>
                    </div>
                    <h4>${item.title}</h4>
                    <div class="muted">${item.module} В· ${item.actor}</div>
                    <div class="muted"><strong>Entry:</strong> ${item.entry}</div>
                    <div class="muted">${item.summary}</div>
                    <button class="seq-btn" data-sequence="${item.id}">Xem Sequence</button>
                </div>
            `).join("");

            host.querySelectorAll("[data-sequence]").forEach(button => {
                button.addEventListener("click", () => openSequence(button.getAttribute("data-sequence")));
            });
        }

        async function ensureMermaid() {
            if (mermaidApi) {
                return mermaidApi;
            }

            try {
                const module = await import("https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs");
                mermaidApi = module.default;
                mermaidApi.initialize({
                    startOnLoad: false,
                    securityLevel: "loose",
                    theme: "neutral",
                    fontFamily: "Segoe UI Variable, Aptos, Segoe UI, sans-serif"
                });
                return mermaidApi;
            } catch {
                return null;
            }
        }

        async function renderDiagram(definition, container) {
            const api = await ensureMermaid();
            if (!api) {
                container.innerHTML = `<div class="code-fallback">${escapeHtml(definition || "No diagram")}</div>`;
                return;
            }

            try {
                const id = `diagram-${Math.random().toString(36).slice(2)}`;
                const { svg } = await api.render(id, definition);
                container.innerHTML = svg;
            } catch {
                container.innerHTML = `<div class="code-fallback">${escapeHtml(definition || "No diagram")}</div>`;
            }
        }

        async function openSequence(id) {
            const item = features.find(row => row.id === id);
            if (!item) {
                return;
            }

            document.getElementById("modalTitle").textContent = `${item.id} В· ${item.title}`;
            document.getElementById("modalMeta").textContent = `${item.module} | Actor: ${item.actor} | Entry: ${item.entry} | Source: ${item.source}`;
            const host = document.getElementById("modalDiagram");
            host.innerHTML = "";
            await renderDiagram(item.mermaid, host);
            document.getElementById("sequenceOverlay").classList.add("active");
        }

        function wireModal() {
            const overlay = document.getElementById("sequenceOverlay");
            const close = () => overlay.classList.remove("active");

            document.getElementById("closeModal").addEventListener("click", close);
            overlay.addEventListener("click", event => {
                if (event.target === overlay) {
                    close();
                }
            });
            window.addEventListener("keydown", event => {
                if (event.key === "Escape") {
                    close();
                }
            });
        }
        // =============================================
        // ACTIVITY DIAGRAM DATA
        // =============================================
        const activityDiagrams = [
            {
                id: 'bootstrap',
                title: 'A01 вЂ” Visitor Bootstrap & BбєЇt Д‘бє§u tham quan',
                desc: 'ToГ n bб»™ luб»“ng tб»« lГєc Visitor mб»џ app, nhбє­p API URL, bootstrap dб»Ї liб»‡u, cбєҐp quyб»Ѓn GPS, bбє­t tracking cho Д‘бєїn khi bбєЇt Д‘бє§u nhбє­n audio tб»± Д‘б»™ng.',
                sequences: 'J01, F05, F07',
                actors: 'Visitor, Mobile App, Backend API, SQL Server',
                meta: [
                    { title: 'User Actions', items: ['Mб»џ б»©ng dб»Ґng AudioTourApp', 'Nhбє­p hoбє·c giб»Ї nguyГЄn API Base URL', 'BбєҐm nГєt Bootstrap / Bбє­t Tracking', 'CбєҐp quyб»Ѓn vб»‹ trГ­ khi OS hб»Џi'] },
                    { title: 'System Processing', items: ['<code>POST /api/user</code> вЂ” Sync visitor profile', '<code>GET /api/bootstrap?lang=</code> вЂ” TбєЈi POI + Tour', 'Khб»џi Д‘б»™ng Foreground Service GPS', '<code>POST /api/tracking</code> вЂ” Gб»­i batch GPS Д‘б»‹nh kб»і'] },
                    { title: 'Database Operations', items: ['<code>SELECT/INSERT Visitors</code> вЂ” Upsert visitor', '<code>SELECT Pois WHERE IsActive=true</code>', '<code>SELECT Tours WHERE IsActive=true</code>', '<code>INSERT UserTrackings</code> вЂ” LЖ°u GPS points'] }
                ],
                mermaid: `flowchart TD
    START(( )) --> A1["рџ§‘ Visitor mб»џ AudioTourApp"]
    A1 --> A2["рџ§‘ Nhбє­p API Base URL\\nhoбє·c giб»Ї mбє·c Д‘б»‹nh"]
    A2 --> A3["рџ“± POST /api/user\\nSync visitor profile"]
    A3 --> DB1[("рџ’ѕ UPSERT Visitors\\ntheo userId hoбє·c deviceId")]
    DB1 --> D1{"Visitor mб»›i\\nhay Д‘ГЈ tб»“n tбєЎi?"}
    D1 -- Mб»›i --> A4["рџ“± TбєЎo profile mб»›i\\nAllowAutoPlay = true"]
    D1 -- ДђГЈ cГі --> A5["рџ“± Cбє­p nhбє­t LastSeenAt\\nLбєҐy Language tб»« server"]
    A4 --> A6["рџ§‘ BбєҐm nГєt Bootstrap"]
    A5 --> A6
    A6 --> A7["рџ“± GET /api/bootstrap?lang=vi"]
    A7 --> DB2[("рџ’ѕ SELECT Pois\\nWHERE IsActive = true")]
    DB2 --> DB3[("рџ’ѕ SELECT Tours\\nWHERE IsActive = true")]
    DB3 --> DB4[("рџ’ѕ SELECT PoiTranslations\\nWHERE IsPublished = true")]
    DB4 --> A8["рџ“± Parse & cache\\nPOI + Tour + Category"]
    A8 --> A9["рџ“± Hiб»ѓn thб»‹ Map + Danh sГЎch POI"]
    A9 --> A10["рџ§‘ BбєҐm Bбє­t Tracking"]
    A10 --> D2{"OS Location\\nPermission?"}
    D2 -- Granted --> A11["рџ“± StartForegroundService\\nGPS interval = 10s"]
    D2 -- Denied --> A12["рџ“± Hiб»‡n thГґng bГЎo\\nyГЄu cбє§u cбєҐp quyб»Ѓn"]
    A12 --> D3{"Visitor vГ o\\nSettings cбєҐp quyб»Ѓn?"}
    D3 -- CГі --> A11
    D3 -- KhГґng --> A13["рџ“± ChбєЎy khГґng tracking\\nChб»‰ xem POI thб»§ cГґng"]
    A11 --> A14["рџ“± Timer GPS callback\\nmб»—i 10 giГўy"]
    A14 --> A15["рџ“± POST /api/tracking\\nbatch GPS data"]
    A15 --> DB5[("рџ’ѕ INSERT UserTrackings\\nlat, lng, speed, bearing")]
    DB5 --> A16["рџ“± Дђб»“ng thб»ќi gб»Ќi\\nPOST /api/geofence"]
    A16 --> ENDOK(("вњ… Tracking Active\\nSбєµn sГ ng nhбє­n trigger"))
    A13 --> ENDMANUAL(("рџ“– Chбєї Д‘б»™ thб»§ cГґng"))`
            },
            {
                id: 'geofence',
                title: 'A02 вЂ” Geofence Check & Auto-Play Audio',
                desc: 'Luб»“ng xб»­ lГЅ khi app gб»­i toбєЎ Д‘б»™ GPS lГЄn server, backend Д‘ГЎnh giГЎ geofence, kiб»ѓm tra anti-spam, trбєЈ kбєїt quбєЈ vГ  mobile phГЎt audio tб»± Д‘б»™ng.',
                sequences: 'J02, F06, F08',
                actors: 'Mobile App, Backend API, SQL Server, Audio Engine',
                meta: [
                    { title: 'Decision Points', items: ['Distance <= Radius hay ApproachRadius?', 'TriggerMode = enter / nearby / manual / both?', 'CooldownUntil <= now? (hбєїt cooldown chЖ°a)', 'Debounce check: trigger gбє§n nhбєҐt > debounceSeconds?', 'AudioUrl hay TtsScript Д‘б»ѓ phГЎt?'] },
                    { title: 'Parallel Flows', items: ['Fork: App vб»«a phГЎt audio, vб»«a tiбєїp tб»Ґc tracking GPS', 'Fork: PhГЎt audio xong, POST /api/visit song song vб»›i PlayNext()', 'Audio queue xб»­ lГЅ tuбє§n tб»± nhЖ°ng tracking chбєЎy song song'] },
                    { title: 'Database Operations', items: ['<code>SELECT Pois WHERE IsActive</code> вЂ” Load POI gбє§n', '<code>SELECT GeofenceTriggers</code> вЂ” Check cooldown', '<code>INSERT GeofenceTriggers</code> вЂ” Ghi trigger mб»›i', '<code>INSERT VisitHistories</code> вЂ” Ghi lЖ°б»Јt nghe'] }
                ],
                mermaid: `flowchart TD
    START(( )) --> A1["рџ“± Location update callback\\nlat, lng, accuracy"]
    A1 --> A2["рџ“± POST /api/geofence\\nuserId, lat, lng, language"]
    A2 --> DB1[("рџ’ѕ SELECT Pois\\nWHERE IsActive = true")]
    DB1 --> A3["вљ™пёЏ TГ­nh khoбєЈng cГЎch Haversine\\ntб»›i tб»«ng Active POI"]
    A3 --> D1{"distance <= radius?"}
    D1 -- KhГґng --> D2{"distance <= approachRadius?"}
    D2 -- KhГґng --> RES1["вљ™пёЏ Response: ShouldPlay = false\\nStatus = out_of_range"]
    D2 -- CГі --> RES2["вљ™пёЏ Response: ShouldPlay = false\\nStatus = approaching\\nNearbyPois list"]
    D1 -- CГі --> A4["вљ™пёЏ TГ¬m POI gбє§n nhбєҐt\\ntrong Radius"]
    A4 --> D3{"TriggerMode?"}
    D3 -- "manual" --> RES3["вљ™пёЏ ShouldPlay = false\\nReason = manual_mode"]
    D3 -- "enter / nearby / both" --> A5["вљ™пёЏ Kiб»ѓm tra Anti-Spam"]
