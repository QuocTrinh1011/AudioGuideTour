                    { title: 'CГЎc trбєЎng thГЎi', items: ['<code>AppOpened</code> вЂ” Vб»«a mб»џ app', '<code>Bootstrapped</code> вЂ” ДђГЈ tбєЈi dб»Ї liб»‡u', '<code>PermissionGranted</code> вЂ” ДђГЈ cбєҐp quyб»Ѓn GPS', '<code>Tracking</code> вЂ” GPS Д‘ang gб»­i toбєЎ Д‘б»™', '<code>Exploring</code> вЂ” Дђang nghe audio'] },
                    { title: 'Actions', items: ['AppOpened в†’ Bootstrapped: GET /api/bootstrap', 'Bootstrapped в†’ PermissionGranted: OS.RequestPermission()', 'Tracking в†’ Exploring: Geofence trigger'] }
                ],
                mermaid: `stateDiagram-v2
    [*] --> AppOpened : Visitor mб»џ б»©ng dб»Ґng
    AppOpened --> Bootstrapped : BбєҐm Bootstrap\\n/ GET /api/bootstrap
    Bootstrapped --> PermissionGranted : OS cбєҐp quyб»Ѓn vб»‹ trГ­
    Bootstrapped --> PermissionDenied : OS tб»« chб»‘i
    PermissionDenied --> Bootstrapped : Visitor vГ o Settings cбєҐp quyб»Ѓn
    PermissionDenied --> SessionEnded : TбєЇt app
    PermissionGranted --> Tracking : BбєҐm Bбє­t Tracking\\n/ StartForegroundService()
    state Tracking {
        [*] --> Sending
        Sending --> Waiting : POST /tracking OK
        Waiting --> Sending : Timer interval hбєїt
    }
    Tracking --> Exploring : Geofence trigger kГ­ch hoбєЎt
    state Exploring {
        [*] --> Listening
        Listening --> MapViewing : Audio kбєїt thГєc
        MapViewing --> Listening : Trigger POI mб»›i
    }
    Exploring --> Tracking : Rб»ќi vГ№ng POI
    Tracking --> SessionEnded : BбєҐm TбєЇt Tracking
    Exploring --> SessionEnded : TбєЇt app
    SessionEnded --> [*]`
            },
            {
                id: 'geofence', title: 'Geofence Trigger',
                desc: 'MГЎy trбєЎng thГЎi Д‘ГЎnh giГЎ geofence вЂ” kiб»ѓm tra khoбєЈng cГЎch, mode, cooldown vГ  debounce.',
                dbField: 'GeofenceTriggers.Status + CooldownUntil', sequences: 'J02, F06',
                meta: [
                    { title: 'CГЎc trбєЎng thГЎi', items: ['<code>Idle</code> вЂ” NgoГ i vГ№ng geofence', '<code>Approaching</code> вЂ” Trong ApproachRadius', '<code>InsideZone</code> вЂ” Trong Radius', '<code>Triggered</code> вЂ” ДђГЈ ghi trigger + phГЎt audio', '<code>Cooldown</code> вЂ” Дђang chб»ќ hбєїt cooldown', '<code>Skipped</code> вЂ” Bб»‹ chбє·n'] },
                    { title: 'Guards', items: ['Approaching в†’ InsideZone: distance в‰¤ Radius', 'InsideZone в†’ Triggered: Cooldown hбєїt + Debounce OK', 'InsideZone в†’ Skipped: CooldownUntil > now'] }
                ],
                mermaid: `stateDiagram-v2
    [*] --> Idle : Visitor mб»џ tracking
    Idle --> Approaching : VГ o ApproachRadius
    Idle --> InsideZone : VГ o thбєіng Radius
    Approaching --> InsideZone : Tiбєїn gбє§n hЖЎn
    Approaching --> Idle : Дђi xa ra
    InsideZone --> Evaluating : Kiб»ѓm tra Д‘iб»Ѓu kiб»‡n Trigger
    state Evaluating {
        [*] --> CheckMode
        CheckMode --> CheckCooldown : Mode != manual
        CheckMode --> ManualOnly : Mode = manual
        CheckCooldown --> CheckDebounce : CooldownUntil hбєїt
        CheckCooldown --> CooldownActive : CooldownUntil cГІn
        CheckDebounce --> PassAll : Debounce OK
        CheckDebounce --> DebounceActive : QuГЎ nhanh
    }
    Evaluating --> Triggered : ThoбєЈ tбєҐt cбєЈ Д‘iб»Ѓu kiб»‡n
    Evaluating --> Skipped : Vi phбєЎm rule
    Triggered --> Cooldown : Ghi CooldownUntil
    Cooldown --> Idle : Hбєїt cooldown
    Skipped --> Idle : Location update tiбєїp theo`
            },
            {
                id: 'audio', title: 'Audio Playback (Mobile)',
                desc: 'MГЎy trбєЎng thГЎi Д‘iб»Ѓu khiб»ѓn hГ ng Д‘б»Јi audio вЂ” quбєЈn lГЅ phГЎt tuбє§n tб»±, TTS fallback vГ  ghi visit history.',
                dbField: 'VisitHistories (kбєїt quбєЈ playback)', sequences: 'J02, F06, F08',
                meta: [
                    { title: 'CГЎc trбєЎng thГЎi', items: ['<code>Idle</code> вЂ” KhГґng cГі audio trong queue', '<code>Queued</code> вЂ” CГі audio chб»ќ phГЎt', '<code>Playing</code> вЂ” Дђang phГЎt audio file', '<code>PlayingTTS</code> вЂ” Дђang phГЎt TTS', '<code>Completed</code> вЂ” PhГЎt xong, ghi visit'] },
                    { title: 'Actions', items: ['Queued в†’ Playing: MediaPlayer.Start(url)', 'Playing в†’ Completed: POST /api/visit', 'Error в†’ PlayingTTS: Fallback'] }
                ],
                mermaid: `stateDiagram-v2
    [*] --> Idle : App khб»џi Д‘б»™ng
    Idle --> Queued : Geofence trigger\\n/ Enqueue(audioUrl, tts)
    Queued --> Playing : CГі AudioUrl\\n/ MediaPlayer.Start(url)
    Queued --> PlayingTTS : KhГґng cГі AudioUrl\\n/ TTS.Speak(script)
    Playing --> Paused : Interruption
    Paused --> Playing : Resume
    Playing --> Completed : PhГЎt xong
    Playing --> Error : Lб»—i load
    PlayingTTS --> Completed : TTS Д‘б»Ќc xong
    PlayingTTS --> Error : TTS engine lб»—i
    Error --> PlayingTTS : Fallback TTS
    Error --> Completed : KhГґng cГі fallback
    Completed --> Queued : Queue cГІn bГ i\\n/ POST /api/visit
    Completed --> Idle : Queue hбєїt\\n/ POST /api/visit`
            },
            {
                id: 'admin', title: 'Admin Session',
                desc: 'VГІng Д‘б»ќi phiГЄn Д‘Дѓng nhбє­p Admin вЂ” kiб»ѓm soГЎt bбєЈo mбє­t vГ  timeout session 8 giб»ќ.',
                dbField: 'AdminUsers + Session Cookie', sequences: 'F11, J03',
                meta: [
                    { title: 'CГЎc trбєЎng thГЎi', items: ['<code>Anonymous</code> вЂ” ChЖ°a Д‘Дѓng nhбє­p', '<code>FirstBoot</code> вЂ” Hб»‡ thб»‘ng rб»—ng', '<code>Authenticated</code> вЂ” ДђГЈ login, session hб»Јp lб»‡', '<code>Expired</code> вЂ” Session hбєїt hбєЎn 8 giб»ќ'] },
                    { title: 'Guards', items: ['Anonymous в†’ FirstBoot: AdminUsers.Count == 0', 'Anonymous в†’ Authenticated: Hash(input) == PasswordHash', 'Authenticated в†’ Expired: SessionAge > 8h'] }
                ],
                mermaid: `stateDiagram-v2
    [*] --> Anonymous : Truy cбє­p Admin site
    Anonymous --> FirstBoot : DB Admin trб»‘ng
    Anonymous --> Authenticated : Login thГ nh cГґng\\n/ CreateSession()
    Anonymous --> Anonymous : Sai mбє­t khбє©u
    FirstBoot --> Authenticated : ДђДѓng kГЅ Admin Д‘бє§u tiГЄn\\n/ INSERT AdminUser
    state Authenticated {
        [*] --> Dashboard
        Dashboard --> ContentManagement : VГ o quбєЈn lГЅ nб»™i dung
        ContentManagement --> Dashboard : Quay vб»Ѓ dashboard
        Dashboard --> Analytics : Xem bГЎo cГЎo
        Analytics --> Dashboard : Quay vб»Ѓ
    }
    Authenticated --> Expired : Hбєїt hбєЎn 8 giб»ќ
