    Expired --> Anonymous : Redirect vб»Ѓ Login
    LoggedOut --> Anonymous : Redirect vб»Ѓ Login`
            },
            {
                id: 'tracking', title: 'Tracking Service (GPS)',
                desc: 'MГЎy trбєЎng thГЎi dб»‹ch vб»Ґ GPS Foreground Service вЂ” quбєЈn lГЅ chu kб»і thu thбє­p vГ  gб»­i toбєЎ Д‘б»™.',
                dbField: 'UserTrackings (batch records)', sequences: 'J01, F07',
                meta: [
                    { title: 'CГЎc trбєЎng thГЎi', items: ['<code>Stopped</code> вЂ” Service chЖ°a chбєЎy', '<code>Starting</code> вЂ” Дђang khб»џi Д‘б»™ng', '<code>Collecting</code> вЂ” Дђang lбєҐy GPS', '<code>Sending</code> вЂ” Дђang POST batch', '<code>Retrying</code> вЂ” Gб»­i thбєҐt bбєЎi, retry', '<code>Paused</code> вЂ” App ra background'] },
                    { title: 'Actions', items: ['Starting в†’ Collecting: OS.StartLocationUpdates(interval)', 'Collecting в†’ Sending: POST /api/tracking', 'Sending fail в†’ Retrying: SaveToLocalCache()'] }
                ],
                mermaid: `stateDiagram-v2
    [*] --> Stopped : App khб»џi Д‘б»™ng
    Stopped --> Starting : BбєҐm Bбє­t Tracking\\n/ RequestPermission()
    Starting --> Collecting : Permission OK\\n/ OS.StartLocationUpdates(10s)
    Starting --> Stopped : Permission Denied
    state Collecting {
        [*] --> WaitingGPS
        WaitingGPS --> GotSample : OS callback
        GotSample --> Batching : ThГЄm vГ o buffer
        Batching --> WaitingGPS : Buffer chЖ°a Д‘бє§y
        Batching --> ReadyToSend : Buffer Д‘б»§ hoбє·c timer
    }
    Collecting --> Sending : Batch sбєµn sГ ng\\n/ POST /api/tracking
    Sending --> Collecting : 200 OK
    Sending --> Retrying : Timeout hoбє·c 503
    Retrying --> Sending : Network recovery
    Retrying --> Collecting : Retry thГ nh cГґng
    Collecting --> Paused : App vГ o background
    Paused --> Collecting : App quay lбєЎi foreground
    Collecting --> Stopped : BбєҐm TбєЇt Tracking
    Paused --> Stopped : BбєҐm TбєЇt Tracking
    Stopped --> [*] : TбєЇt app`
            },
            {
                id: 'membership', title: 'Membership Registration',
                desc: 'VГІng Д‘б»ќi Д‘Дѓng kГЅ thГ nh viГЄn вЂ” tб»« Д‘iб»Ѓn form, chб»ќ thanh toГЎn, xГЎc nhбє­n thanh toГЎn Д‘бєїn tбєЎo tГ i khoбєЈn customer hoбє·c huб»·.',
                dbField: 'MembershipRegistrations.Status + PaymentStatus', sequences: 'QR01, QR02',
                meta: [
                    { title: 'CГЎc trбєЎng thГЎi', items: ['<code>pending-form</code> вЂ” Visitor vб»«a tбєЎo Д‘Дѓng kГЅ, chЖ°a Д‘iб»Ѓn form', '<code>pending-payment</code> вЂ” Form Д‘ГЈ Д‘iб»Ѓn, chб»ќ thanh toГЎn', '<code>paid</code> вЂ” Thanh toГЎn thГ nh cГґng, tбєЎo CustomerAccount', '<code>cancelled</code> вЂ” Huб»· bб»џi visitor hoбє·c timeout', '<code>expired</code> вЂ” QuГЎ hбєЎn thanh toГЎn'] },
                    { title: 'Actions', items: ['pending-form в†’ pending-payment: Visitor submit form Д‘бє§y Д‘б»§', 'pending-payment в†’ paid: PayOS webhook xГЎc nhбє­n', 'paid в†’ CustomerAccount created: TбєЎo tГ i khoбєЈn tб»± Д‘б»™ng', 'pending-payment в†’ cancelled: Visitor hoбє·c admin huб»·'] }
                ],
                mermaid: `stateDiagram-v2
    [*] --> PendingForm : Visitor bбєЇt Д‘бє§u Д‘Дѓng kГЅ
    PendingForm --> PendingPayment : Submit form Д‘бє§y Д‘б»§\\n/ SET Status=pending-payment
    PendingForm --> Cancelled : Timeout hoбє·c huб»·
    PendingPayment --> Paid : PayOS webhook\\n/ SET PaymentStatus=PAID
    PendingPayment --> Cancelled : Visitor huб»· Д‘ЖЎn
    PendingPayment --> Expired : QuГЎ hбєЎn thanh toГЎn
    Paid --> AccountCreated : TбєЎo CustomerAccount\\n/ INSERT CustomerAccount
    state AccountCreated {
        [*] --> Active
        Active --> Inactive : Admin tбєЇt tГ i khoбєЈn
        Inactive --> Active : Admin kГ­ch hoбєЎt lбєЎi
    }
    Cancelled --> [*]
    Expired --> [*]`
            },
            {
                id: 'qrcode', title: 'QR Code Lifecycle',
                desc: 'VГІng Д‘б»ќi mГЈ QR вЂ” tб»« tбєЎo mГЈ, liГЄn kбєїt POI, Д‘бєїn cГЎc dбєЎng Д‘бє·c biб»‡t nhЖ° BatchBusStop vГ  AppEntry.',
                dbField: 'QRCodes.Code + PoiId', sequences: 'QR01, QR02, A14, F10',
                meta: [
                    { title: 'CГЎc trбєЎng thГЎi', items: ['<code>Created</code> вЂ” MГЈ vб»«a tбєЎo, liГЄn kбєїt POI', '<code>BusStop</code> вЂ” MГЈ batch xe buГЅt (BUS-KH-001)', '<code>AppEntry</code> вЂ” MГЈ Д‘бє·c biб»‡t APP-ENTRY, chб»©a deep link', '<code>Scanned</code> вЂ” ДђГЈ Д‘Ж°б»Јc visitor quГ©t (web hoбє·c app)', '<code>Deleted</code> вЂ” Bб»‹ xoГЎ'] },
                    { title: 'Transitions', items: ['Created в†’ Scanned: Visitor quГ©t bбє±ng app hoбє·c web', 'BusStop: TбєЎo bб»џi CreateBusStopSet batch', 'AppEntry: TбєЎo bб»џi RenderAppEntryPng'] }
                ],
                mermaid: `stateDiagram-v2
    [*] --> Created : Admin tбєЎo QR thб»§ cГґng
    [*] --> BusStop : CreateBusStopSet batch\\n/ INSERT QR BUS-KH-001
    [*] --> AppEntry : RenderAppEntryPng\\n/ Deep link audiotour://
    Created --> LinkedToPoi : GГЎn PoiId\\n[Code UNIQUE]
    BusStop --> LinkedToPoi : FindBusStopPoi match\\n/ UPDATE PoiId
    state LinkedToPoi {
        [*] --> Waiting
        Waiting --> ScannedWeb : Visitor quГ©t bбє±ng browser\\n/ TriggerType=qr-public
        Waiting --> ScannedApp : Visitor quГ©t bбє±ng app\\n/ TriggerType=qr-scan
