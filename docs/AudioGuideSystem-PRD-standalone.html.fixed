    LinkedToPoi --> Updated : Admin sб»­a PoiId hoбє·c Note
    Updated --> LinkedToPoi : LЖ°u thГ nh cГґng
    LinkedToPoi --> Deleted : Admin xoГЎ QR
    Deleted --> [*]`
            }
        ];

        // =============================================
        // RENDER FUNCTIONS FOR EMBEDDED DIAGRAMS
        // =============================================

        async function renderActivitySection() {
            const navBar = document.getElementById('activityTabBar');
            const contentEl = document.getElementById('activityContent');
            if (!navBar || !contentEl) return;

            // Shortcut buttons вЂ” scroll to diagram anchor
            navBar.innerHTML = activityDiagrams.map(a =>
                `<button class="toolbar-btn" onclick="document.getElementById('act-anchor-${a.id}').scrollIntoView({behavior:'smooth',block:'start'})">${a.title.split('\u2014')[0].trim()}</button>`
            ).join('');

            // Render ALL diagrams stacked vertically
            contentEl.innerHTML = activityDiagrams.map(a => `
                <div id="act-anchor-${a.id}" style="margin-top:2rem;">
                    <div class="card">
                        <h3 style="color:var(--primary-dark);margin:0 0 0.3rem;">${a.title}</h3>
                        <p class="muted" style="margin-bottom:1rem;">${a.desc}</p>
                        <div class="grid-3" style="margin-bottom:1rem;">
                            ${a.meta.map(m => `
                                <div class="card" style="background:#f8fafc;">
                                    <h4 style="font-size:0.78rem;text-transform:uppercase;color:var(--accent);margin-bottom:0.4rem;">${m.title}</h4>
                                    <ul style="font-size:0.82rem;padding-left:1.1rem;">${m.items.map(it => `<li>${it}</li>`).join('')}</ul>
                                </div>
                            `).join('')}
                        </div>
                        <p class="muted" style="font-size:0.82rem;"><strong>Actors:</strong> ${a.actors} &middot; <strong>Sequences:</strong> ${a.sequences}</p>
                        <div class="diagram-panel" style="margin-top:0.8rem;"><div class="diagram-stage" id="act-stage-${a.id}"></div></div>
                    </div>
                </div>
            `).join('');

            // Render all diagrams sequentially
            for (const a of activityDiagrams) {
                await renderDiagram(a.mermaid, document.getElementById(`act-stage-${a.id}`));
            }
        }

        async function renderClassSection() {
            const navBar = document.getElementById('classTabBar');
            const contentEl = document.getElementById('classContent');
            if (!navBar || !contentEl) return;

            // Shortcut buttons вЂ” scroll to diagram anchor
            navBar.innerHTML = classTabInfo.map(t =>
                `<button class="toolbar-btn" onclick="document.getElementById('cls-anchor-${t.key}').scrollIntoView({behavior:'smooth',block:'start'})">${t.label}</button>`
            ).join('');

            // Render ALL class diagrams stacked vertically
            contentEl.innerHTML = classTabInfo.map(t => `
                <div id="cls-anchor-${t.key}" style="margin-top:2rem;">
                    <div class="diagram-panel">
                        <h4 style="margin:0 0 0.5rem;font-size:0.9rem;color:var(--accent);text-transform:uppercase;">${t.label}</h4>
                        <div class="diagram-stage" id="cls-stage-${t.key}"></div>
                    </div>
                </div>
            `).join('');

            // Render all class diagrams sequentially
            for (const t of classTabInfo) {
                await renderDiagram(classDiagrams[t.key], document.getElementById(`cls-stage-${t.key}`));
            }
        }

        async function renderStateSection() {
            const navBar = document.getElementById('stateTabBar');
            const contentEl = document.getElementById('stateContent');
            if (!navBar || !contentEl) return;

            // Shortcut buttons вЂ” scroll to diagram anchor
            navBar.innerHTML = stateDiagrams.map(s =>
                `<button class="toolbar-btn" onclick="document.getElementById('st-anchor-${s.id}').scrollIntoView({behavior:'smooth',block:'start'})">${s.title}</button>`
            ).join('');

            // Render ALL state diagrams stacked vertically
            contentEl.innerHTML = stateDiagrams.map(s => `
                <div id="st-anchor-${s.id}" style="margin-top:2rem;">
                    <div class="card">
                        <h3 style="color:var(--primary-dark);margin:0 0 0.3rem;">${s.title}</h3>
                        <p class="muted" style="margin-bottom:1rem;">${s.desc}</p>
                        <div class="grid-3" style="margin-bottom:1rem;">
                            ${s.meta.map(m => `
                                <div class="card" style="background:#f8fafc;">
                                    <h4 style="font-size:0.78rem;text-transform:uppercase;color:var(--accent);margin-bottom:0.4rem;">${m.title}</h4>
                                    <ul style="font-size:0.82rem;padding-left:1.1rem;">${m.items.map(it => `<li>${it}</li>`).join('')}</ul>
                                </div>
                            `).join('')}
                        </div>
                        <p class="muted" style="font-size:0.82rem;"><strong>DB Field:</strong> <code>${s.dbField}</code> &middot; <strong>Sequences:</strong> ${s.sequences}</p>
                        <div class="diagram-panel" style="margin-top:0.8rem;"><div class="diagram-stage" id="st-stage-${s.id}"></div></div>
                    </div>
                </div>
            `).join('');

            // Render all state diagrams sequentially
            for (const s of stateDiagrams) {
                await renderDiagram(s.mermaid, document.getElementById(`st-stage-${s.id}`));
            }
        }

        // =============================================
        // INIT
        // =============================================
        async function init() {
            renderStaticSections();
            document.getElementById("featureCount").textContent = String(features.length);
            renderInventory();
            renderToolbar("All");
            renderSequenceCards("All");
            wireModal();
            // Render architecture first, then each diagram section sequentially
            await renderDiagram(architectureDefinition, document.getElementById("architectureDiagram"));
            await renderActivitySection();
            await renderClassSection();
            await renderStateSection();
        }

        init();
    </script>
</body>

</html>